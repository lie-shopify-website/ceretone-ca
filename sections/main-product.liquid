{% comment %}theme-check-disable TemplateLength{% endcomment %}

{% comment %} 页面重构, 不加载这些无效CSS
{{ 'section-main-product.css' | asset_url | stylesheet_tag }}
{{ 'component-accordion.css' | asset_url | stylesheet_tag }}
{{ 'component-badge.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-rte.css' | asset_url | stylesheet_tag }}

{% if section.settings.render_css_file != blank %}
  <link rel="stylesheet" href="{{ section.settings.render_css_file | asset_url }}" media="all">
{% endif %}

<link rel="stylesheet" href="{{ 'component-cart-drawer.css' | asset_url }}" media="all">
<link rel="stylesheet" href="{{ 'component-deferred-media.css' | asset_url }}" media="all">
<link rel="stylesheet" href="{{ 'component-card.css' | asset_url }}" media="print" onload="this.media='all'">
<link
  rel="stylesheet"
  href="{{ 'section-product-recommendations.css' | asset_url }}"
  media="print"
  onload="this.media='all'"
>
{% endcomment %}

{{ 'custom-main-product.css' | asset_url | stylesheet_tag }}

<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'copy.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'update-slider.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'main-product.js' | asset_url }}" defer="defer"></script>

{%- assign first_3d_model = product.media | where: 'media_type', 'model' | first -%}
{%- if first_3d_model -%}
  {{ 'component-product-model.css' | asset_url | stylesheet_tag }}
  <link
    id="ModelViewerStyle"
    rel="stylesheet"
    href="https://cdn.shopify.com/shopifycloud/model-viewer-ui/assets/v1.0/model-viewer-ui.css"
    media="print"
    onload="this.media='all'"
  >
  <link
    id="ModelViewerOverride"
    rel="stylesheet"
    href="{{ 'component-model-viewer-ui.css' | asset_url }}"
    media="print"
    onload="this.media='all'"
  >
{%- endif -%}

{%- if settings.quickview_show or settings.show_on_mobile -%}
  <link
    rel="preload"
    href="{{ 'quick-add.css' | asset_url }}"
    as="style"
    onload="this.onload=null;this.rel='stylesheet'"
  >
{%- endif -%}

{%- style -%}
  {% render 'section-padding' %}
{%- endstyle -%}

<style>

  .swiper-wrapper {
      display: flex;
      box-sizing: content-box;
  }
  .swiper-slide {
    flex-shrink: 0;
    display: block;
  }
  .swiper-android .swiper-slide, .swiper-ios .swiper-slide, .swiper-wrapper {
      transform: translate3d(0px, 0, 0);
  }

  .list-payment__item_svg svg{
    height: 2.5rem!important;
  }
  .price_flex{
    display: flex;
    width: 100%;
    align-items: center;
  }
  .price_flex_img img{
    display: block;
    width: 12rem;
    height: auto;
    margin-right: 1rem;
  }
  .Metafield_Newproduct{
    top: 0.5rem;
    left: 0.5rem;
  }
  @media(max-width: 768px) {
   .breadcrumb{
     order: 1;
   }
   .price_flex_img img{
    width: 10rem;
  }
   .list-payment__item_svg svg{
      height: 2.5rem!important;
   }
  }
</style>

{% comment %} Collapsible Tab {% endcomment %}
<script>
window.addEventListener('DOMContentLoaded', function() {
  $('.collapsible-item .collapsible-title').on('click', function(){
      let collItem = $(this).parents('.collapsible-item');
      if(collItem.hasClass('open')){
        collItem.removeClass('open');
      }else{
        collItem.addClass('open');
      }
  });
});
</script>


<section id="MainProduct-{{ section.id }}" data-section="{{ section.id }}" class="section-{{ section.id }}-padding main-product-section">
  <div
    id="product_scrollup"
    class="product {% if product.media.size > 0 %}row{% else %}product--no-media{% endif %} product--{% if section.settings.gallery_type == 'slider_previews' %}slider-previews{% elsif section.settings.gallery_type == 'slider_bullets' %}slider-bullets{% elsif section.settings.gallery_type == 'stacked_gallery' %}stacked-gallery{% elsif section.settings.gallery_type == 'grid_gallery' %}grid-gallery{% endif %} safe-container"
  >
    <div
      class="
        product__outer product__outer--{% if section.settings.gallery_type == 'slider_previews' %}slider-previews{% elsif section.settings.gallery_type == 'slider_bullets' %}slider-bullets{% elsif section.settings.gallery_type == 'stacked_gallery' %}stacked-gallery{% elsif section.settings.gallery_type == 'grid_gallery' %}grid-gallery{% endif %}
        {% if section.settings.desktop_alignment == 'right' %}product__outer--desktop-order{% endif %}
        {% if section.settings.mobile_alignment == 'after' %}product__outer--mobile-order{% endif %}
      "
    >
      <div class="product__main" data-section="main-{{ section.id }}">
        {% if settings.show_breadcrumbs %}
          <nav class="breadcrumb breadcrumb__desktop body-small" role="navigation" aria-label="breadcrumbs">
            <a href="{{ routes.root_url }}" title="{{ 'general.breadcrumbs.home' | t }}">
              {{- 'general.breadcrumbs.home' | t -}}
            </a>
            <div class="breadcrumb__delimiter"></div>
            <a href="{{ routes.collections_url }}">{{ 'products.product.shop' | t }}</a>
            <div class="breadcrumb__delimiter"></div>
            {% if product.collections[0] %}
              <a href="{{ product.collections[0].url }}">{{ product.collections[0].title }} </a>
              <div class="breadcrumb__delimiter"></div>
            {% endif %}
            <span>{{ product.title }}</span>
          </nav>
        {% endif %}

        {% if section.settings.enable_new_media_section %}
          <link rel="stylesheet" href="{{ 'media-gallery.css' | asset_url }}" media="all">
          {% render 'media-gallery', product: product, section:section %}   {% comment %} 新版媒体模块 {% endcomment %}
        {% else %}

          {% if product.media.size > 0 %}
            <div class="product__media-wrapper">
              <div class="product__media-list-wrapper">
                {% comment %} 元字段 {% endcomment %}
                {% if product.metafields.custom.Newproduct != blank %}
                  <div class="Metafield_Newproduct">{{ product.metafields.custom.Newproduct }}</div>
                {%- endif -%}
                <div class="product__media-list {% if section.settings.gallery_type != 'grid_gallery' and section.settings.gallery_type != 'stacked_gallery' %}js-media-list swiper {% endif %} {% if section.settings.gallery_type == 'grid_gallery' and product.media.size == 1 %} product__media-list--full{% endif %} no-js-hidden">
                  {% if section.settings.gallery_type != 'grid_gallery'
                    and section.settings.gallery_type != 'stacked_gallery'
                  %}
                    <div class="swiper-wrapper">
                  {% endif %}
                  {%- liquid
                    assign variant_images = product.images | where: 'attached_to_variant?', true | map: 'src'
                    assign media_count = product.media.size
                  -%}

                  {%- if product.selected_or_first_available_variant.featured_media != null -%}
                    {%- assign featured_media = product.selected_or_first_available_variant.featured_media -%}
                    {% if section.settings.aspect_ratio != 'adapt' %}
                      {% liquid
                        assign aspect_ratio = section.settings.aspect_ratio | split: '/'
                        assign temp = aspect_ratio[0] | append: '.0'
                        assign padding_bottom = aspect_ratio[1] | divided_by: temp | times: 100 | round: 2
                      %}
                    {% elsif section.settings.aspect_ratio == 'adapt' %}
                      {% assign padding_bottom = 1
                        | divided_by: featured_media.preview_image.aspect_ratio
                        | times: 100
                        | round: 2
                      %}
                    {% else %}
                      {% assign padding_bottom = 0 %}
                    {% endif %}
                    <div
                      class="product__media-item active swiper-slide {% if section.settings.image_fit == 'contain' %}product__media-item--contain{% endif %}"
                      data-media-id="{{ section.id }}-{{ featured_media.id }}"
                    >
                      {% render 'product-thumbnail',
                        product_card_product: product,
                        media: featured_media,
                        position: 'featured',
                        modal_id: section.id,
                        lazy_load: false,
                        padding_bottom: padding_bottom
                      %}
                    </div>
                  {%- endif -%}

                  {%- for media in product.media -%}
                    {% if section.settings.aspect_ratio != 'adapt' %}
                      {% liquid
                        assign aspect_ratio = section.settings.aspect_ratio | split: '/'
                        assign temp = aspect_ratio[0] | append: '.0'
                        assign padding_bottom = aspect_ratio[1] | divided_by: temp | times: 100 | round: 2
                      %}
                    {% elsif section.settings.aspect_ratio == 'adapt' %}
                      {% assign padding_bottom = 1
                        | divided_by: media.preview_image.aspect_ratio
                        | times: 100
                        | round: 2
                      %}
                    {% else %}
                      {% assign padding_bottom = 0 %}
                    {% endif %}
                    {%- unless media.id == product.selected_or_first_available_variant.featured_media.id -%}
                      <div
                        class="product__media-item {% if product.selected_or_first_available_variant.featured_media == null and forloop.index == 1 %}active{% endif %} swiper-slide{% if media.media_type != 'image' %} product__media-item--full{% endif %} {% if variant_images contains media.src %} product__media-item--variant{% endif %} {% if section.settings.image_fit == 'contain' %} product__media-item--contain{% endif %}"
                        data-media-id="{{ section.id }}-{{ media.id }}"
                      >
                        {% render 'product-thumbnail',
                          media: media,
                          position: forloop.index,
                          modal_id: section.id,
                          lazy_load: false,
                          padding_bottom: padding_bottom
                        %}
                      </div>
                    {%- endunless -%}
                  {%- endfor -%}
                  {% if section.settings.gallery_type != 'grid_gallery'
                    and section.settings.gallery_type != 'stacked_gallery'
                  %}
                    </div>
                  {% endif %}
                </div>
                {% if section.settings.gallery_type != 'grid_gallery'
                  and section.settings.gallery_type != 'stacked_gallery'
                %}
                  {% if product.media.size > 1 %}
                    <div class="product__slider-nav no-js-hidden">
                      <div class="swiper-button-prev focus-inset">
                        <svg width="29" height="29" style="transform: rotate(180deg);" viewBox="0 0 29 29" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <g opacity="0.5">
                          <rect width="18.5667" height="15.5256" transform="matrix(-4.37114e-08 -1 -1 4.37114e-08 21.6875 22.8082)" fill="#FFFEFB"/>
                          <path d="M14.0396 13.9707L13.9708 14.0394C13.9927 14.0144 14.0145 13.9925 14.0396 13.9707Z" fill="white"/>
                          <path d="M14.005 28.01C6.271 28.01 0 21.739 0 14.005C0 6.27099 6.271 -1.33514e-05 14.005 -1.33514e-05C21.739 -1.33514e-05 28.01 6.27099 28.01 14.005C28.01 21.739 21.739 28.01 14.005 28.01ZM17.6876 13.3298L17.6188 13.261L16.9467 12.5889L11.7667 7.4089C11.3791 7.02126 10.7414 7.02126 10.3506 7.4089C9.96295 7.79654 9.96295 8.43427 10.3506 8.82503L15.5337 14.005L10.3537 19.1881C9.96607 19.5758 9.96607 20.2135 10.3537 20.6043C10.7414 20.9919 11.3791 20.9919 11.7667 20.6011L16.9467 15.4211L17.6282 14.7397L17.6845 14.6834C17.8502 14.5052 17.9502 14.2645 17.9471 14.0019C17.9471 13.7424 17.8502 13.508 17.6876 13.3298Z" fill="#2D2D2D"/>
                          </g>
                        </svg>
                      </div>
                      <div class="swiper-button-next focus-inset">
                        <svg width="29" height="29" viewBox="0 0 29 29" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <g opacity="0.5">
                        <rect width="18.5667" height="15.5256" transform="matrix(-4.37114e-08 -1 -1 4.37114e-08 21.6875 22.8082)" fill="#FFFEFB"/>
                        <path d="M14.0396 13.9707L13.9708 14.0394C13.9927 14.0144 14.0145 13.9925 14.0396 13.9707Z" fill="white"/>
                        <path d="M14.005 28.01C6.271 28.01 0 21.739 0 14.005C0 6.27099 6.271 -1.33514e-05 14.005 -1.33514e-05C21.739 -1.33514e-05 28.01 6.27099 28.01 14.005C28.01 21.739 21.739 28.01 14.005 28.01ZM17.6876 13.3298L17.6188 13.261L16.9467 12.5889L11.7667 7.4089C11.3791 7.02126 10.7414 7.02126 10.3506 7.4089C9.96295 7.79654 9.96295 8.43427 10.3506 8.82503L15.5337 14.005L10.3537 19.1881C9.96607 19.5758 9.96607 20.2135 10.3537 20.6043C10.7414 20.9919 11.3791 20.9919 11.7667 20.6011L16.9467 15.4211L17.6282 14.7397L17.6845 14.6834C17.8502 14.5052 17.9502 14.2645 17.9471 14.0019C17.9471 13.7424 17.8502 13.508 17.6876 13.3298Z" fill="#2D2D2D"/>
                        </g>
                        </svg>
                      </div>
                    </div>
                  {% endif %}
                {% endif %}

                <div class="product__media-grid-noscript js-hidden">
                  <div class="product__media-list">
                    {%- if product.selected_or_first_available_variant.featured_media != null -%}
                      {%- assign featured_media = product.selected_or_first_available_variant.featured_media -%}
                      {% if section.settings.aspect_ratio != 'adapt' %}
                        {% liquid
                          assign aspect_ratio = section.settings.aspect_ratio | split: '/'
                          assign temp = aspect_ratio[0] | append: '.0'
                          assign padding_bottom = aspect_ratio[1] | divided_by: temp | times: 100 | round: 2
                        %}
                      {% elsif section.settings.aspect_ratio == 'adapt' %}
                        {% assign padding_bottom = 1
                          | divided_by: featured_media.preview_image.aspect_ratio
                          | times: 100
                          | round: 2
                        %}
                      {% else %}
                        {% assign padding_bottom = 0 %}
                      {% endif %}
                      <div
                        class="product__media-item {% if section.settings.image_fit == 'contain' %}product__media-item--contain{% endif %}"
                        data-media-id="{{ section.id }}-{{ featured_media.id }}"
                      >
                        {% render 'product-thumbnail',
                          product_card_product: product,
                          media: featured_media,
                          position: 'featured',
                          modal_id: section.id,
                          lazy_load: false,
                          padding_bottom: padding_bottom
                        %}
                      </div>
                    {%- endif -%}

                    {%- for media in product.media -%}
                      {% if section.settings.aspect_ratio != 'adapt' %}
                        {% liquid
                          assign aspect_ratio = section.settings.aspect_ratio | split: '/'
                          assign temp = aspect_ratio[0] | append: '.0'
                          assign padding_bottom = aspect_ratio[1] | divided_by: temp | times: 100 | round: 2
                        %}
                      {% elsif section.settings.aspect_ratio == 'adapt' %}
                        {% assign padding_bottom = 1
                          | divided_by: media.preview_image.aspect_ratio
                          | times: 100
                          | round: 2
                        %}
                      {% else %}
                        {% assign padding_bottom = 0 %}
                      {% endif %}
                      {%- unless media.id == product.selected_or_first_available_variant.featured_media.id -%}
                        <div
                          class="product__media-item {% if media.media_type != 'image' %} product__media-item--full{% endif %} {% if variant_images contains media.src %} product__media-item--variant{% endif %} {% if section.settings.image_fit == 'contain' %} product__media-item--contain{% endif %}"
                          data-media-id="{{ section.id }}-{{ media.id }}"
                        >
                          {% render 'product-thumbnail',
                            media: media,
                            position: forloop.index,
                            modal_id: section.id,
                            lazy_load: false,
                            padding_bottom: padding_bottom
                          %}
                        </div>
                      {%- endunless -%}
                    {%- endfor -%}
                  </div>
                </div>
              </div>
              {% if section.settings.gallery_type == 'slider_previews' and product.media.size > 1 %}
                <div class="product__media-sublist-outer no-js-hidden">
                  <div class="product__media-sublist {% if product.media.size < 4 %}product__media-sublist--{{ product.media.size }}{% endif %} js-media-sublist swiper">
                    <div class="swiper-wrapper">
                      {%- if product.selected_or_first_available_variant.featured_media != null -%}
                        {%- assign featured_media = product.selected_or_first_available_variant.featured_media -%}
                        {% if section.settings.aspect_ratio != 'adapt' %}
                          {% liquid
                            assign aspect_ratio = section.settings.aspect_ratio | split: '/'
                            assign temp = aspect_ratio[0] | append: '.0'
                            assign padding_bottom = aspect_ratio[1] | divided_by: temp | times: 100 | round: 2
                          %}
                        {% elsif section.settings.aspect_ratio == 'adapt' %}
                          {% assign padding_bottom = 1
                            | divided_by: featured_media.preview_image.aspect_ratio
                            | times: 100
                            | round: 2
                          %}
                        {% else %}
                          {% assign padding_bottom = 0 %}
                        {% endif %}
                        <div
                          class="product__media-subitem swiper-slide {% if section.settings.image_fit == 'contain' %} product__media-item--contain{% endif %}"
                          data-media-sub-id="{{ section.id }}-{{ featured_media.id }}"
                        >
                          <div class="product__media" style="padding-bottom: {{ padding_bottom }}%">
                            {%- capture style -%}
                              object-position: {{ featured_media.presentation.focal_point }};
                            {%- endcapture -%}
                            {{
                              featured_media.preview_image
                              | image_url: width: 800
                              | image_tag:
                                loading: 'lazy',
                                height: '187',
                                widths: '150, 200, 250, 300, 400, 500, 600, 700, 800',
                                style: style
                            }}
                          </div>
                        </div>
                      {%- endif -%}

                      {%- for media in product.media -%}
                        {% if section.settings.aspect_ratio != 'adapt' %}
                          {% liquid
                            assign aspect_ratio = section.settings.aspect_ratio | split: '/'
                            assign temp = aspect_ratio[0] | append: '.0'
                            assign padding_bottom = aspect_ratio[1] | divided_by: temp | times: 100 | round: 2
                          %}
                        {% elsif section.settings.aspect_ratio == 'adapt' %}
                          {% assign padding_bottom = 1
                            | divided_by: media.preview_image.aspect_ratio
                            | times: 100
                            | round: 2
                          %}
                        {% else %}
                          {% assign padding_bottom = 0 %}
                        {% endif %}
                        {%- unless media.id == product.selected_or_first_available_variant.featured_media.id -%}
                          <div
                            class="product__media-subitem a2222222 swiper-slide {% if variant_images contains media.src %} product__media-item--variant{% endif %} {% if section.settings.image_fit == 'contain' %} product__media-item--contain{% endif %}"
                            data-media-sub-id="{{ section.id }}-{{ media.id }}"
                          >
                            <div class="product__media" style="padding-bottom: {{ padding_bottom }}%">
                              {%- capture style -%}
                                object-position: {{ media.presentation.focal_point }};
                              {%- endcapture -%}
                              <picture>
                                <img src="{{ media.preview_image | image_url: width: 100 }}" width="auto" height="auto" />
                              </picture>
                            </div>
                          </div>
                        {%- endunless -%}
                      {%- endfor -%}
                    </div>
                  </div>
                </div>
              {% endif %}
              {% if section.settings.gallery_type != 'grid_gallery'
                and section.settings.gallery_type != 'stacked_gallery'
              %}
                {% if product.media.size > 1 %}
                  <div class="product__pagination swiper-pagination"></div>
                {% endif %}
              {% endif %}
            </div>
          {% else %}
            {% if section.settings.aspect_ratio != 'adapt' %}
              {% liquid
                assign aspect_ratio = section.settings.aspect_ratio | split: '/'
                assign temp = aspect_ratio[0] | append: '.0'
                assign padding_bottom = aspect_ratio[1] | divided_by: temp | times: 100 | round: 2
              %}
            {% elsif section.settings.aspect_ratio == 'adapt' %}
              {% assign padding_bottom = 1 | divided_by: media.preview_image.aspect_ratio | times: 100 | round: 2 %}
            {% else %}
              {% assign padding_bottom = 0 %}
            {% endif %}
            <div class="product__media-wrapper">
              <div class="product__media-list-wrapper">
                <div class="product__media-list {% if section.settings.gallery_type == 'grid_gallery' %} product__media-list--full{% endif %}">
                  <div class="product__media-item">
                    <div class="product__media media" style="padding-bottom: {{ padding_bottom }}%">
                      {{ 'product-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                    </div>
                  </div>
                </div>
              </div>
            </div>
          {% endif %}

        {% endif %}  
      </div>

      <div id="ProductInfo-{{ section.id }}" data-section="{{ section.id }}" class="product__info-container">
        {% comment %}
        {% if product.metafields.custom.custom._GiftBox != blank %}
          <div class="gift-box">
            {% assign giftbox_product = all_products[product.metafields.custom.custom._GiftBox] %}
            {% if giftbox_product %}
              <p class="gift-box-title">{{ giftbox_product.title }}</p>
              <p class="gift-box-description">{{ giftbox_product.description }}</p>
            {% endif %}
          </div>
        {% endif %}
        {% endcomment %}

        {%- assign product_form_id = 'product-form-' | append: section.id -%}
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'text' -%}
              <div
                class="product__block product__text subtitle"
                style="color: {{ block.settings.color }};font-size: {{ block.settings.font_size |  append: 'rem' }};"
                {{ block.shopify_attributes }}
              >
                {% if block.settings.text != blank %}
                  {{ block.settings.text }}
                {% endif %}
              </div>

            {%- when 'title' -%}
              <div
                class="product__block product__title__wrapper
                  {%- if product.available == false %} price--sold-out {% endif -%}
                  {%- if product.compare_at_price > product.price %} price--on-sale {% endif -%}
                "
              >
                <h1 class="product__title {{ block.settings.heading_size }}" {{ block.shopify_attributes }}>
                  {{ product.title | escape }}
                </h1>
              </div>

            {%- when 'tags' -%}
              {%- if product.tags != blank -%}
                <ul class="product__block product-tags product__tags list-unstyled" style="--tag-color:{{ block.settings.color }};--tag-background-color:{{ block.settings.bg_color }};">
                  {% for tag in product.tags %}
                    <li class="product-tags__tag">{{ tag }}</li>
                  {% endfor %}
                </ul>
              {%- endif -%}

            {%- when 'price' -%}
              <div class="product__block product-price-box price_flex">
                <div class="price_flex_img">
                  {% if block.settings.image != blank %}
                    {{
                      block.settings.image
                      | image_url: width: block.settings.image.width
                      | image_tag:
                        loading: 'lazy',
                        widths: '360, 533, 720, 940, 1066, 1200, 1400, 1600, 1800, 2000',
                        sizes: sizes
                    }}
                  {% endif %}
                </div>
                <div class="price_flex_box">
                  <div class="no-js-hidden price-wrapper" id="price-{{ section.id }}" {{ block.shopify_attributes }}>
                    {%- render 'price',
                      product: product,
                      use_variant: true,
                      show_badges: true,
                      price_class: 'price--product'
                    -%}

                    {%- if settings.badge_sale_show -%}
                      <div class="product__badge">
                        {%- if product.selected_or_first_available_variant.compare_at_price
                            > product.selected_or_first_available_variant.price
                          and product.available
                          and settings.badge_sale_show
                        -%}
                          <span
                            class="badge badge--sale color-{{ settings.badge_sale_color_scheme }} bold"
                            aria-hidden="true"
                          >
                            {% if settings.badge_sale_type == 'sale' %}
                              {% comment %} {{- 'products.product.on_sale' | t -}} {% endcomment %}
                              Save
                            {% else %}
                              {% comment %} {{- 'products.product.on_sale' | t -}} {% endcomment %}
                              Save
                              <span>
                                {{
                                  product.selected_or_first_available_variant.compare_at_price
                                  | minus: product.selected_or_first_available_variant.price
                                  | times: 100
                                  | divided_by: product.selected_or_first_available_variant.compare_at_price
                                }}
                                %
                              </span>
                            {% endif %}
                          </span>
                        {%- endif -%}
                      </div>
                    {%- endif -%}

