            {%- when 'newcountdown' -%}
              <style>
                .newcountdown_big {
                  display: flex;
                  align-items: center;
                  justify-content: {{ block.settings.flex_direction }};
                  background-color: {{ block.settings.body_color }};
                  text-align: {{ block.settings.buttonid }};
                  padding: 20px 10px;
                  border-radius: 30px;
                  width: auto;
                }
                .newcountdown_h2 {
                  font-weight: 700;
                  font-size: {{ block.settings.headerfu_micsiez }}px;
                  margin: 0;
                }
                .newcountdown_p {
                  margin: 10px 0;
                  cursor: pointer;
                }
                .newcountdown_p span{
                  padding: 5px;
                  background-color: {{ block.settings.Discount_colora }};
                  border-radius: 10px;
                  margin-top: 10px;
                  display: inline-block;
                }
                .newcountdown {
                  display: flex;
                  margin-left: 15px;
                }
                .newcountdown p {
                  display: flex;
                  flex-direction: column;
                  text-align: center;
                  margin: 0 5px;
                }
                .newcountdownspan {
                  background-color: {{ block.settings.timebody_color }};
                  color: {{ block.settings.time_color }};
                  font-weight: 500;
                  font-size: 20px;
                  padding: 10px;
                  border-radius: 10px;
                }
                .newcountdownspancolor {
                  color: {{ block.settings.time_colorx }};
                  margin-top: 5px;
                  font-size: 1.4rem;
                }
                @media(max-width: 768px) {
                  .newcountdown_big {
                    display: block;
                  }
                  .newcountdown {
                    justify-content: center;
                    margin-left: 0;
                  }
                }
              </style>
              <div class="product__block newcountdown_big">
                {% comment %}设置截止日期{% endcomment %}
                {% assign deadline = block.settings.time %}

                {% comment %}计算剩余时间{% endcomment %}
                {% assign now = 'now' | date: '%s' %}
                {% assign end = deadline | date: '%s' %}
                {% assign remaining_seconds = end | minus: now %}
                {% comment %}将剩余时间转换为天、小时、分钟和秒{% endcomment %}
                {% assign remaining_days = remaining_seconds | divided_by: 86400 %}
                {% assign remaining_hours = remaining_seconds | divided_by: 3600 | modulo: 24 %}
                {% assign remaining_minutes = remaining_seconds | divided_by: 60 | modulo: 60 %}
                {% assign remaining_seconds = remaining_seconds | modulo: 60 %}

                <div>
                  {%- if block.settings.header != blank -%}
                    <h2 class="newcountdown_h2" style="color:{{ block.settings.header_color }};">
                      {{ block.settings.header }}
                    </h2>
                  {%- endif -%}
                  {%- if block.settings.text != blank -%}
                    <p class="newcountdown_p" style="color:{{ block.settings.header_colora }};">
                      {{ block.settings.text }}
                      {%- if block.settings.Discount != blank -%}
                        <span>
                          {{ block.settings.Discount }}
                        </span>
                      {%- endif -%}
                    </p>
                  {%- endif -%}
                </div>

                {% comment %}显示倒计时{% endcomment %}

                {% if remaining_seconds >= 0 %}
                  {%- if block.settings.time != blank -%}
                    <div
                      class="newcountdown"
                      id="countdown"
                    >
                      <p style="margin-left: 0;">
                        <span class="newcountdownspan" id="newdays"> {{ remaining_days }}</span>
                        <span class="newcountdownspancolor">Days</span>
                      </p>
                      <p>
                        <span class="newcountdownspan" id="newhours"> {{ remaining_hours }}</span>
                        <span class="newcountdownspancolor">Hours</span>
                      </p>
                      <p>
                        <span class="newcountdownspan" id="newminutes"> {{ remaining_minutes }}</span>
                        <span class="newcountdownspancolor">Mins</span>
                      </p>
                      <p>
                        <span class="newcountdownspan" id="newseconds">
                          {{ remaining_seconds }}
                        </span>
                        <span class="newcountdownspancolor">Secs</span>
                      </p>
                    </div>
                  {%- endif -%}
                  <script>
                    // 更新倒计时
                    function updateCountdown() {
                      var daysElement = document.getElementById('newdays');
                      var hoursElement = document.getElementById('newhours');
                      var minutesElement = document.getElementById('newminutes');
                      var secondsElement = document.getElementById('newseconds');

                      // 将元素的 innerHTML 转换为数字
                      var days = parseInt(daysElement.innerHTML);
                      var hours = parseInt(hoursElement.innerHTML);
                      var minutes = parseInt(minutesElement.innerHTML);
                      var seconds = parseInt(secondsElement.innerHTML);

                      // 减少剩余时间
                      if (days > 0 || hours > 0 || minutes > 0 || seconds > 0) {
                        if (seconds > 0) {
                          seconds--;
                        } else {
                          if (minutes > 0) {
                            minutes--;
                            seconds = 59;
                          } else {
                            if (hours > 0) {
                              hours--;
                              minutes = 59;
                              seconds = 59;
                            } else {
                              if (days > 0) {
                                days--;
                                hours = 23;
                                minutes = 59;
                                seconds = 59;
                              }
                            }
                          }
                        }
                      }

                      // 将数字格式化为带前导零的字符串
                      daysElement.innerHTML = days < 10 ? '0' + days : days;
                      hoursElement.innerHTML = hours < 10 ? '0' + hours : hours;
                      minutesElement.innerHTML = minutes < 10 ? '0' + minutes : minutes;
                      secondsElement.innerHTML = seconds < 10 ? '0' + seconds : seconds;
                    }

                    // 每秒更新一次倒计时
                    setInterval(updateCountdown, 1000);
                    const pElement = document.querySelector('.newcountdown_p');
                    const spanElement = document.querySelector('.newcountdown_p span');
                    pElement.addEventListener('click', function() {
                        copyToClipboard(spanElement.innerText.trim());
                    });
                    function copyToClipboard(text) {
                        const input = document.createElement('textarea');
                        input.style.position = 'fixed';
                        input.style.opacity = 0;
                        input.value = text;
                        document.body.appendChild(input);
                        input.select();
                        document.execCommand('copy');
                        document.body.removeChild(input);
                        const successMessage = document.createElement('div');
                        successMessage.textContent = 'Copied';
                        successMessage.style.position = 'fixed';
                        successMessage.style.top = '50%';
                        successMessage.style.left = '50%';
                        successMessage.style.transform = 'translate(-50%, -50%)';
                        successMessage.style.padding = '20px 35px';
                        successMessage.style.backgroundColor = '#28be44';
                        successMessage.style.color = '#fff';
                        successMessage.style.borderRadius = '24px';
                        successMessage.style.fontSize = '2rem';
                        successMessage.style.boxShadow = '0 4px 8px rgba(0, 0, 0, 0.1)';
                        successMessage.style.zIndex = 9999;

                        document.body.appendChild(successMessage);

                        setTimeout(function() {
                            document.body.removeChild(successMessage);
                        }, 3000);
                    }
                  </script>
                {% endif %}
              </div>

