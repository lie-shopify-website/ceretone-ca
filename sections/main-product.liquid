                    <button
                      id="ModalClose-{{ block.id }}"
                      type="button"
                      class="product-popup-modal__close modal-close-button focus-inset"
                      aria-label="{{ 'accessibility.close' | t }}"
                    >
                      {% render 'icon-close' %}
                    </button>
                    <div class="product-popup-modal__content-info">
                      <h3 class="product-popup-modal__title h4">
                        {{ block.settings.heading }}
                      </h3>
                      <div class="product-popup-modal__text">
                        {{ block.settings.text }}
                      </div>
                      {% if block.settings.image != blank %}
                        <div class="product-popup-modal__image-wrapper">
                          {%- liquid
                            assign sizes = '(min-width: 1200px) calc((100vw - 10rem) / 2), (min-width: 750px) calc((100vw - 10rem) / 2), calc(100vw - 4rem)'
                            assign widths = '246, 493, 600, 713, 800, 900, 1000'
                          -%}
                          {{
                            block.settings.image
                            | image_url: width: 1000
                            | image_tag:
                              loading: 'lazy',
                              widths: widths,
                              sizes: sizes,
                              class: 'product-popup-modal__image'
                          }}
                        </div>
                      {% endif %}
                      {%- if block.settings.page.content != blank -%}
                        {{ block.settings.page.content }}
                      {%- endif -%}
                    </div>
                  </div>
                </modal-dialog>
              </div>

            {%- when 'dropdown_information' -%}
              <div class="product__block about">
                <div class="about__accordion-item" {{ block.shopify_attributes }}>
                  <button
                    class="about__accordion-toggle {% if block.settings.default_open %}active{% endif %} button--unstyled"
                    area-label="toggle"
                  >
                    <span class="h6">{{ block.settings.heading | escape }}</span>
                    <div class="about__accordion-toggle-icon">
                      {% render 'icon-button-arrow' %}
                    </div>
                  </button>
                  <div
                    class="about__accordion-description"
                    {% if block.settings.default_open %}
                      style="display: block;"
                    {% endif %}
                  >
                    {% if block.settings.characteristics %}
                      {%- if product.metafields.characteristics.name.value.size > 0 -%}
                        {%- for item in product.metafields.characteristics.name.value -%}
                          <div class="about__row">
                            <span>{{ item }}</span>
                            <span>{{ product.metafields.characteristics.description.value[forloop.index0] }}</span>
                          </div>
                        {% endfor %}
                      {% endif %}
                    {% else %}
                      {% if block.settings.description != blank %}
                        {{ block.settings.description }}
                      {% endif %}

                      {%- if block.settings.button_show -%}
                        <a
                          {% if block.settings.button_link != blank %}
                            href="{{ block.settings.button_link }}"
                          {% endif %}
                          class="about__button button button--simple button--arrow focus-inset"
                          {% if block.settings.button_link == blank %}
                            aria-disabled="true"
                          {% endif %}
                        >
                          <span>{{ block.settings.button_label }}</span>
                          {% render 'icon-button-arrow' %}
                        </a>
                      {%- endif -%}
                    {% endif %}
                  </div>
                </div>
              </div>
            {%- when '@app' -%}
              <div class="product__block app-block">
              {% render block %}
              </div>

            {%- when 'short_info' -%}
                <div class="product__block short-info">
                  <div class="short-info__inner">{{ block.settings.text | newline_to_br }}</div>
                </div>

            {%- when 'collapsible' -%}
                <div class="product__block collapsible-item {% if block.settings.is_open %}open{% endif %}">
                    <div class="collapsible-ly">
                        <div class="collapsible-title">
                            <div class="c-title-text">{{ block.settings.collapsible_text }}</div>
                            <div class="c-title-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false" role="presentation" class="icon icon-arrow" xmlns="http://www.w3.org/2000/svg">
                              <path fill-rule="evenodd" clip-rule="evenodd" d="M13.451 4.24896C13.1191 3.91701 12.5809 3.91701 12.249 4.24896C11.917 4.5809 11.917 5.1191 12.249 5.45104L17.7977 10.9998L3.85 10.9998C3.38056 10.9998 3 11.3803 3 11.8498C3 12.3192 3.38056 12.6998 3.85 12.6998L17.7982 12.6998L12.249 18.249C11.917 18.5809 11.917 19.1191 12.249 19.451C12.5809 19.783 13.1191 19.783 13.451 19.451L20.451 12.451C20.5003 12.4018 20.5429 12.3471 20.5782 12.2885C20.6501 12.1691 20.692 12.033 20.699 11.8921C20.6996 11.8781 20.7 11.8641 20.7 11.85C20.7 11.8499 20.7 11.8498 20.7 11.8498C20.7 11.6089 20.5998 11.3914 20.4388 11.2367L13.451 4.24896Z" fill="currentColor"></path>
                            </svg></div>
                        </div>
                        <div class="collapsible-info">
                            <div class="collapsible-info-ly">
                              {% if block.settings.collapsible_content != blank %} 
                                <div class="collapsible-content">{{ block.settings.collapsible_content }}</div>
                              {% endif %}
                            </div>
                        </div>
                    </div>
                </div>


            {%- when 'product_featured_info' -%}

              {% if product.metafields.custom.product_featured_info != blank %}
                <div class="product__block product_featured_info">
                  <ul class="feature-list">
                    {% if product.metafields.custom.product_featured_info.list? %}
                      {% for feature in product.metafields.custom.product_featured_info.value %}
                        <li class="feature-item">{{ feature | strip }}</li>
                      {% endfor %}
                    {% endif %}
                  </ul>
                </div>
              {% endif %}

            {%- when 'limited_time_gift' -%}
              {% comment %} 加购动作在product-form.js里完成 {% endcomment %}
              {% if product.metafields.custom._GiftBox != blank %}
                <div class="product__block limited_time_gift">
                  <div class="gift-box-heading">{{ block.settings.heading }}</div>
                  
                  <div class="gift_box-area">
                    {% for giftbox_product in product.metafields.custom._GiftBox.value %}
                      <div class="gift_box">
                        <input type="checkbox" class="hidden gift-box-checkbox" value="{{ giftbox_product.selected_or_first_available_variant.id }}" checked />
                        <span class="gift-box-title">{{ giftbox_product.title }}</span>
                        <div class="gift-box-price">
                          <span class="price-at">{{ giftbox_product.price | money }}</span>
                          <span class="price-zore">{{ '0' | money | replace:'.00', '' }}</span>
                        </div>
                      </div>
                    {% endfor %}
                  </div>
                </div>
              {% endif %}
                

            {%- when 'service_icon' -%}
              <div class="product__block service_icon">
                <div class="service_icon-items">
                  {% for i in (1..3) %}
                    {% capture text %}text{{ i }}{% endcapture %}
                    {% capture service_icon %}service_icon{{ i }}{% endcapture %}
                  
                    {% if block.settings[text] != blank and block.settings[service_icon] != blank %}
                    <div class="icon-item">
                      <div class="icon"><img src="{{ block.settings[service_icon] |  image_url: width: 200 }}" width="auto" height="auto" /></div>
                      <div class="text">{{ block.settings[text] }}</div>
                    </div>
                    {% endif %}
                  {% endfor %}
                </div>
              </div>
                


          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>

    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'complementary' -%}
          {%- style -%}
            .complementary-products__container {
            	{% if block.settings.padding_top == 'no-indent' %}
            		padding-top: 0;
            	{% else %}
            		padding-top: 3.2rem;
            	{% endif %}

            	{% if block.settings.padding_bottom == 'no-indent' %}
            		padding-bottom: 0;
            	{% else %}
            		padding-bottom: 3.2rem;
            	{% endif %}
            }

            @media screen and (min-width: 576px) {
            	.complementary-products__container {
            		{% if block.settings.padding_top == 'no-indent' %}
            			padding-top: 0;
            		{% elsif block.settings.padding_top == 'xl' %}
            			padding-top: 4.8rem;
            		{% else %}
            			padding-top: 3.2rem;
            		{% endif %}

            		{% if block.settings.padding_bottom == 'no-indent' %}
            			padding-bottom: 0;
            		{% elsif block.settings.padding_bottom == 'xl' %}
            			padding-bottom: 4.8rem;
            		{% else %}
            			padding-bottom: 3.2rem;
            		{% endif %}
            	}
            }

            @media screen and (min-width: 990px) {
            	.complementary-products__container {
            		{% if block.settings.padding_top == 'no-indent' %}
            			padding-top: 0;
            		{% elsif block.settings.padding_top == 'xl' %}
            			padding-top: 8.8rem;
            		{% elsif block.settings.padding_top == 'l' %}
            			padding-top: 4.8rem;
            		{% else %}
            			padding-top: 3.2rem;
            		{% endif %}

            		{% if block.settings.padding_bottom == 'no-indent' %}
            			padding-bottom: 0;
            		{% elsif block.settings.padding_bottom == 'xl' %}
            			padding-bottom: 8.8rem;
            		{% elsif block.settings.padding_bottom == 'l' %}
            			padding-bottom: 4.8rem;
            		{% else %}
            			padding-bottom: 3.2rem;
            		{% endif %}
            	}
            }

            @media screen and (min-width: 1200px) {
            	.complementary-products__container {
            		{% if block.settings.padding_top == 'no-indent' %}
            			padding-top: 0;
            		{% elsif block.settings.padding_top == 'xl' %}
            			padding-top: 12rem;
            		{% elsif block.settings.padding_top == 'l' %}
            			padding-top: 8.8rem;
            		{% elsif block.settings.padding_top == 'm' %}
            			padding-top: 4.8rem;
            		{% else %}
            			padding-top: 3.2rem;
            		{% endif %}

            		{% if block.settings.padding_bottom == 'no-indent' %}
            			padding-bottom: 0;
            		{% elsif block.settings.padding_bottom == 'xl' %}
            			padding-bottom: 12rem;
            		{% elsif block.settings.padding_bottom == 'l' %}
            			padding-bottom: 8.8rem;
            		{% elsif block.settings.padding_bottom == 'm' %}
            			padding-bottom: 4.8rem;
            		{% else %}
            			padding-bottom: 3.2rem;
            		{% endif %}
            	}
            }

            @media screen and (min-width: 1440px) {
            	.complementary-products__container {
            		{% if block.settings.padding_top == 'no-indent' %}
            			padding-top: 0;
            		{% elsif block.settings.padding_top == 'xl' %}
            			padding-top: 15.2rem;
            		{% elsif block.settings.padding_top == 'l' %}
            			padding-top: 12rem;
            		{% elsif block.settings.padding_top == 'm' %}
            			padding-top: 8.8rem;
            		{% elsif block.settings.padding_top == 's' %}
            			padding-top: 4.8rem;
            		{% else %}
            			padding-top: 3.2rem;
            		{% endif %}

            		{% if block.settings.padding_bottom == 'no-indent' %}
            			padding-bottom: 0;
            		{% elsif block.settings.padding_bottom == 'xl' %}
            			padding-bottom: 15.2rem;
            		{% elsif block.settings.padding_bottom == 'l' %}
            			padding-bottom: 12rem;
            		{% elsif block.settings.padding_bottom == 'm' %}
            			padding-bottom: 8.8rem;
            		{% elsif block.settings.padding_bottom == 's' %}
            			padding-bottom: 4.8rem;
            		{% else %}
            			padding-bottom: 3.2rem;
            		{% endif %}
            	}
            }
          {%- endstyle -%}

          <product-recommendations
            class="complementary-products product-recommendations color-{{ block.settings.color_scheme }}"
            data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&intent=complementary"
            {{ block.shopify_attributes }}
          >
            {% if recommendations.performed and recommendations.products_count > 0 %}
              <div class="complementary-products__container">
                {% render 'section-text', section: block, class: 'product-recommendations' %}
                <div class="product-recommendations__item">
                  {% if recommendations.performed and recommendations.products_count > 0 %}
                    <div
                      class="
                        product-recommendations__list
                        product-recommendations__list--{{ block.settings.columns_mobile }}-mobile
                        js-recommendation-swiper swiper
                      "
                      role="list"
                      data-mobile-layout="{{ block.settings.columns_mobile }}"
                    >
                      <div class="swiper-wrapper">
                        {% for recommendation in recommendations.products limit: block.settings.products_limit %}
                          <div class="swiper-slide collection-product-card product-recommendations__product quickview{%- if settings.quickview_hover -%}--hover{% endif %}">
                            {% render 'product-card',
                              product_card_product: recommendation,
                              media_ratio: block.settings.image_ratio,
                              media_fit: block.settings.image_fit,
                              show_secondary_image: block.settings.show_secondary_image,
                              show_vendor: block.settings.show_vendor,
                              show_desc: block.settings.show_desc,
                              section_id: block.id
                            %}
                          </div>
                        {% endfor %}
                      </div>
                    </div>
                    <div class="product-recommendations__slider-nav">
                      <div class="swiper-button-prev">
                        {% render 'icon-caret-left' %}
                      </div>
                      <div class="swiper-button-next">
                        {% render 'icon-caret-right' %}
                      </div>
                    </div>
                  {% endif %}
                </div>
              </div>
            {% endif %}
          </product-recommendations>
      {% endcase %}
    {% endfor %}
  </div>

  {% if section.settings.enable_new_media_section %}
      <div class="media-gallery">
          {% render 'popup-media-gallery', product: product, section:section %}
           <div class="popup-media-gallery-bottom"></div>
      </div>
  {% else %}
    <product-modal id="ProductModal-{{ section.id }}" class="product-media-modal">
      <div
        class="product-media-modal__dialog"
        role="dialog"
        aria-label="{{ 'products.modal.label' | t }}"
        aria-modal="true"
        tabindex="-1"
      >
        <button
          id="ModalClose-{{ section.id }}"
          type="button"
          class="product-media-modal__toggle modal-close-button focus-inset"
          aria-label="{{ 'accessibility.close' | t }}"
        >
          {% render 'icon-close' %}
        </button>

        <div
          class="product-media-modal__content swiper js-popup-slider"
          role="document"
          aria-label="{{ 'products.modal.label' | t }}"
          tabindex="0"
        >
          <div class="swiper-wrapper">
            {%- for media in product.media -%}
              <div
                class="swiper-slide product-media-modal__item {% if section.settings.image_fit_modal == 'contain' %} product-media-modal__item--contain{% endif %}"
                data-media-modal-id="{{ section.id }}-{{ media.id }}"
              >
                {%- if media.media_type == 'image' -%}
                  {% comment %} {{
                    media.preview_image
                    | image_url: width: media.preview_image.width
                    | image_tag:
                      loading: 'lazy',
                      widths: '550, 1100, 1445, 1680, 1750, 1920, 2048, 2200, 2890, 3000, 3200, 3400, 3600, 3800, 4096',
                      data-media-id: media.id
                  }} {% endcomment %}

                  <picture>
                    <source data-srcset="{{ media.preview_image | image_url: width: 767 }}"  media="(max-width: 767px)" />
                    <source data-srcset="{{ media.preview_image | image_url: width: media.preview_image.width }}" media="(min-width: 768px)" />
                    <img src="data:image/gif;base64,R0lGODlhAQABAAAAACH5BAEKAAEALAAAAAABAAEAAAICTAEAOw==" data-lzsrc="{{ media.preview_image | image_url: width: 767 }}" class="js-lazy" width="auto" height="auto" />
                  </picture>

                {%- else -%}
                  {%- if media.media_type == 'model' -%}
                    <div class="product-media-modal__model" data-media-id="{{ media.id }}">
                      <product-model class="deferred-media media">
                  {%- else -%}
                    <deferred-media class="deferred-media media" data-media-id="{{ media.id }}">
                  {%- endif -%}

                  <button
                    id="Deferred-Poster-Modal-{{ media.id }}"
                    class="deferred-media__poster focus-inset"
                    type="button"
                  >
                    <span class="deferred-media__poster-button motion-reduce">
                      {%- if media.media_type == 'model' -%}
                        {%- render 'icon-3d-model' -%}
                      {%- else -%}
                        {%- render 'icon-play' -%}
                      {%- endif -%}
                    </span>
                    {{
                      media.preview_image
                      | image_url: width: 3600
                      | image_tag:
                        loading: 'lazy',
                        widths: '550, 1100, 1445, 1680, 1750, 1920, 2048, 2200, 2890, 3000, 3200, 3400, 3600, 3800, 4096',
                        data-media-id: media.id
                    }}
                  </button>
                  <template>
                    {%- case media.media_type -%}
                      {%- when 'external_video' -%}
                        {%- assign video_class = 'js-' | append: media.host -%}
                        {%- if media.host == 'youtube' -%}
                          {{
                            media
                            | external_video_url: autoplay: true, loop: loop, playlist: media.external_id
                            | external_video_tag: class: video_class, loading: 'lazy'
                          }}
                        {%- else -%}
                          {{
                            media
                            | external_video_url: autoplay: true, loop: loop
                            | external_video_tag: class: video_class, loading: 'lazy'
                          }}
                        {%- endif -%}
                      {%- when 'video' -%}
                        {{
                          media
                          | media_tag: image_size: '2048x', autoplay: true, loop: loop, controls: true, preload: 'none'
                        }}
                      {%- when 'model' -%}
                        {{ media | media_tag: image_size: '2048x', toggleable: true }}
                    {%- endcase -%}
                  </template>

                  {%- if media.media_type == 'model' -%}
                    </product-model>
                    <button
                      class="button button--tertiary product__xr-button focus-inset"
                      type="button"
                      aria-label="{{ 'products.product.xr_button_label' | t }}"
                      data-shopify-xr
                      data-shopify-model3d-id="{{ media.id }}"
                      data-shopify-title="title"
                      data-shopify-xr-hidden
                    >
                      {% render 'icon-3d-model' %}
                      {{ 'products.product.xr_button' | t }}
                    </button>
                    </div>
                  {%- else -%}
                    </deferred-media>
                  {%- endif -%}
                {%- endif -%}
              </div>
            {%- endfor -%}
          </div>
          <div class="container product__pagination-wrapper">
            <div class="product__pagination swiper-pagination"></div>
          </div>
        </div>
      </div>

      <div class="container product__slider-nav product-media-modal__slider-nav no-js-hidden">
        <div class="swiper-button-prev focus-inset">
          <svg width="29" height="29" style="transform: rotate(180deg);" viewBox="0 0 29 29" fill="none" xmlns="http://www.w3.org/2000/svg">
            <g opacity="0.5">
            <rect width="18.5667" height="15.5256" transform="matrix(-4.37114e-08 -1 -1 4.37114e-08 21.6875 22.8082)" fill="#FFFEFB"/>
            <path d="M14.0396 13.9707L13.9708 14.0394C13.9927 14.0144 14.0145 13.9925 14.0396 13.9707Z" fill="white"/>
            <path d="M14.005 28.01C6.271 28.01 0 21.739 0 14.005C0 6.27099 6.271 -1.33514e-05 14.005 -1.33514e-05C21.739 -1.33514e-05 28.01 6.27099 28.01 14.005C28.01 21.739 21.739 28.01 14.005 28.01ZM17.6876 13.3298L17.6188 13.261L16.9467 12.5889L11.7667 7.4089C11.3791 7.02126 10.7414 7.02126 10.3506 7.4089C9.96295 7.79654 9.96295 8.43427 10.3506 8.82503L15.5337 14.005L10.3537 19.1881C9.96607 19.5758 9.96607 20.2135 10.3537 20.6043C10.7414 20.9919 11.3791 20.9919 11.7667 20.6011L16.9467 15.4211L17.6282 14.7397L17.6845 14.6834C17.8502 14.5052 17.9502 14.2645 17.9471 14.0019C17.9471 13.7424 17.8502 13.508 17.6876 13.3298Z" fill="#2D2D2D"/>
            </g>
          </svg>
        </div>
        <div class="swiper-button-next focus-inset">
          <svg width="29" height="29" viewBox="0 0 29 29" fill="none" xmlns="http://www.w3.org/2000/svg">
            <g opacity="0.5">
            <rect width="18.5667" height="15.5256" transform="matrix(-4.37114e-08 -1 -1 4.37114e-08 21.6875 22.8082)" fill="#FFFEFB"/>
            <path d="M14.0396 13.9707L13.9708 14.0394C13.9927 14.0144 14.0145 13.9925 14.0396 13.9707Z" fill="white"/>
            <path d="M14.005 28.01C6.271 28.01 0 21.739 0 14.005C0 6.27099 6.271 -1.33514e-05 14.005 -1.33514e-05C21.739 -1.33514e-05 28.01 6.27099 28.01 14.005C28.01 21.739 21.739 28.01 14.005 28.01ZM17.6876 13.3298L17.6188 13.261L16.9467 12.5889L11.7667 7.4089C11.3791 7.02126 10.7414 7.02126 10.3506 7.4089C9.96295 7.79654 9.96295 8.43427 10.3506 8.82503L15.5337 14.005L10.3537 19.1881C9.96607 19.5758 9.96607 20.2135 10.3537 20.6043C10.7414 20.9919 11.3791 20.9919 11.7667 20.6011L16.9467 15.4211L17.6282 14.7397L17.6845 14.6834C17.8502 14.5052 17.9502 14.2645 17.9471 14.0019C17.9471 13.7424 17.8502 13.508 17.6876 13.3298Z" fill="#2D2D2D"/>
            </g>
          </svg>
        </div>
      </div>
    </product-modal>
  {% endif %}

  <style>
    .add-to-cart-button{
      position: fixed;
      z-index: 11;
      background: transparent;
      width: 42rem;
      right: 5rem;
      background-color: #fff;
      padding: 1rem;
      box-shadow: 0 0 20px #000;
      top: auto;
      bottom: .8rem;
      opacity: 1;
      transition: opacity 0.3s ease-in-out;
      visibility: visible;
      pointer-events: auto;
      align-items: center;
      justify-content: center;
      display: flex;
      border-radius: 10px;
      transform: translateY(0);
      visibility: visible;
    }
    .add-to-cart-button.hidden {
        opacity: 0;
    }
    .product_image{
      width: 100px;
      height: auto;
      border-radius: 12px;
      margin-right: 2%;
    }
    .product_name{
      margin: 0 0 15px;
      font-size: 20px;
    }
    .addtocart_box form{
      display: flex;
    }
    .addtocart_box .product-form__submit{
      min-height: 3.8rem;
    }
    .addtocart_box .quantity {
      min-height: 3.8rem;
      margin-right: 5px;
    }
    {% comment %} .add-to-cart-button .product-form__submit span{
      font-size: 1.2rem;
    } {% endcomment %}
    @media(max-width: 768px) {
      .add-to-cart-button{
        right: 16px;
        width: 60%;
        transform: unset;
        padding: 0;
        background: transparent;
        box-shadow: 0 0 0px #000;
        justify-content: flex-end;
        bottom: 10px !important;
      }

      .addtocart_box .product-form__submit {
        min-height: 45px;
        min-width: 150px;
      }
      .product_name{
        display: none;
      }
      .addtocart_box .quantity{
        display: none;
      }

      .add-to-cart-button .pii_wrapper {
          --pii-width: 72px;
          --pii-height: 72px;
          border-radius: 50%;
          background: #fff;
          width: var(--pii-width);
          height: var(--pii-height);
          display: flex;
          align-items: center;
          justify-content: center;
      }
      .add-to-cart-button .pii_wrapper_img {
          border-radius: 50%;
          background: #FF4F00;
          width: calc(var(--pii-width) - 6px);
          height: calc(var(--pii-height) - 6px);
          display: flex;
          align-items: center;
          justify-content: center;
      }
      .add-to-cart-button .pii_wrapper_img img {
        border-radius: 50%;
        background: #fff;
        width: calc(var(--pii-width) - 12px);
        height: calc(var(--pii-height) - 12px);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0;
      }

      .add-to-cart-button .product_image_item {
          position: relative;
          right: -30px;
          z-index: 4;
      }
      .add-to-cart-button .addtocart_box {
          position: relative;
          z-index: 3;
      }
    }
  </style>
  {% if section.settings.show_addtocart_btn %}
  <div class="add-to-cart-button hidden js-addtocartBtn {% if product.variants.size == 1 %}single-variant{% else %}muilt-variant{% endif %}">
    {% assign selected_variant = product.selected_or_first_available_variant %}
    {% assign selected_variant_id = selected_variant.id %}
    {% if product.variants.size == 1 %}
      <div class="product_image_item">
        <div class="pii_wrapper">
            <div class="pii_wrapper_img">
            <img
                src="{{ product.featured_image | image_url:width:200 }}"
                alt="{{ product.title }}"
                loading="lazy"
                class="product_image"
                width="200"
                height="auto"
            >
            </div>
        </div>
    </div>
    {% else %}
      {% for variant in product.variants %}
        <div class="product_image_item" 
          data-variant-id="{{ variant.id }}"
          {% unless variant.id == selected_variant_id %} style="display:none;" {% endunless %}>
          <div class="pii_wrapper">
            <div class="pii_wrapper_img">
              <img
                src="{{ variant.featured_image | image_url:width:200 }}"
                alt="{{ variant.title }}"
                loading="lazy"
                class="product_image"
                width="200"
                height="auto"
              >
            </div>
          </div>
        </div>
      {% endfor %}
    {% endif %}

    <div class="addtocart_box">
      <h3 class="product_name">{{ product.title }}</h3>
      <div class="product__buy-buttons" {{ block.shopify_attributes }}>
        {%- liquid
          assign gift_card_recipient_feature_active = false
          if block.settings.show_gift_card_recipient and product.gift_card?
            assign gift_card_recipient_feature_active = true
          endif

          assign show_dynamic_checkout = false
          if block.settings.show_dynamic_checkout and gift_card_recipient_feature_active == false
            assign show_dynamic_checkout = true
          endif
        -%}

        <product-form class="product-form" data-hide-errors="{{ gift_card_recipient_feature_active }}">
          <div class="product-form__error-message-wrapper" role="alert" hidden>
            <svg
              aria-hidden="true"
              focusable="false"
              role="presentation"
              class="icon icon-error"
              viewBox="0 0 13 13"
            >
              <circle cx="6.5" cy="6.50049" r="5.5" stroke="white" stroke-width="2"/>
              <circle cx="6.5" cy="6.5" r="5.5" fill="#EB001B" stroke="#EB001B" stroke-width="0.7"/>
              <path d="M5.87413 3.52832L5.97439 7.57216H7.02713L7.12739 3.52832H5.87413ZM6.50076 9.66091C6.88091 9.66091 7.18169 9.37267 7.18169 9.00504C7.18169 8.63742 6.88091 8.34917 6.50076 8.34917C6.12061 8.34917 5.81982 8.63742 5.81982 9.00504C5.81982 9.37267 6.12061 9.66091 6.50076 9.66091Z" fill="white"/>
              <path d="M5.87413 3.17832H5.51535L5.52424 3.537L5.6245 7.58083L5.63296 7.92216H5.97439H7.02713H7.36856L7.37702 7.58083L7.47728 3.537L7.48617 3.17832H7.12739H5.87413ZM6.50076 10.0109C7.06121 10.0109 7.5317 9.57872 7.5317 9.00504C7.5317 8.43137 7.06121 7.99918 6.50076 7.99918C5.94031 7.99918 5.46982 8.43137 5.46982 9.00504C5.46982 9.57872 5.94031 10.0109 6.50076 10.0109Z" fill="white" stroke="#EB001B" stroke-width="0.7"/>
            </svg>
            <span class="product-form__error-message"></span>
          </div>
          {%- form 'product',
            product,
            id: product_form_id,
            class: 'form',
            novalidate: 'novalidate',
            data-type: 'add-to-cart-form'
          -%}
            <input
              type="hidden"
              name="id"
              value="{{ product.selected_or_first_available_variant.id }}"
              {% if product.selected_or_first_available_variant.available == false %}
                disabled
              {% endif %}
            >

            {%- if gift_card_recipient_feature_active -%}
              {%- render 'gift-card-recipient-form', product: product, form: form, section: section -%}
            {%- endif -%}

            <quantity-input class="quantity">
              <button class="quantity__button no-js-hidden focus-inset" name="minus" type="button">
                <span class="visually-hidden">Decrease quantity for Core One OTC Hearing Aids</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none">
                  <path d="M14 10L6 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
                </svg>
              </button>
              <input
                class="quantity__input focus-inset"
                type="number"
                name="quantity"
                id="quantity"
                data-cart-quantity="0"
                data-min="1"
                min="1"
                step="1"
                value="1"
              >
              <label class="visually-hidden" for="Quantity-template--17816414748892__main"> Quantity </label>
              <button class="quantity__button no-js-hidden focus-inset" name="plus" type="button">
                <span class="visually-hidden">Increase quantity for Core One OTC Hearing Aids</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none">
                  <path d="M10 6L10 14" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
                  <path d="M14 10L6 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"></path>
                </svg>
              </button>
            </quantity-input>

            {% comment %}
              <div class="product-form__quantity">
                  <label for="quantity">数量:</label>
                  <input type="number" id="quantity" name="quantity" value="1" min="1" step="1">
              </div>
            {% endcomment %}

            {% comment %}
              <div class="product-form__variants">
                  <label for="variant">选择属性:</label>
                  <select id="variant" name="variant">
                      {% for variant in product.variants %}
                          <option value="{{ variant.id }}">{{ variant.title }} - {{ variant.price | money }}</option>
                      {% endfor %}
                  </select>
              </div>
            {% endcomment %}

            <div class="product-form__buttons">
              <div class="product-form__buttons-row">
                <button
                  type="submit"
                  name="add"
                  class="product-form__submit button button--{%- if show_dynamic_checkout -%}tertiary{% else %}primary{%- endif -%}"
                  {% if product.selected_or_first_available_variant.available == false %}
                    disabled
                  {% endif %}
                >
                  {%- if product.selected_or_first_available_variant.available -%}
                    <span>
                      {{ 'products.product.add_to_cart' | t }}
                      {% comment %} {% render 'icon-cart' %} {% endcomment %}
                    </span>
                    <div class="loading-overlay__spinner hidden">
                      {%- render 'icon-loading' -%}
                    </div>
                  {%- else -%}
                    <span>
                      {{ 'products.product.sold_out' | t }}
                    </span>
                  {%- endif -%}
                </button>
              </div>
            </div>
          {%- endform -%}
        </product-form>
      </div>
    </div>
  </div>
  <script>
    document.addEventListener("DOMContentLoaded", function() {
        var addToCartButton = document.querySelector(".add-to-cart-button");
        var productScrollUp = document.getElementById('product_scrollup');

        function checkScroll() {
            var scrollPosition = window.scrollY;
            var productScrollUpTop = productScrollUp.getBoundingClientRect().top;
            var productScrollUpBottom = productScrollUp.getBoundingClientRect().bottom;

            // 如果productScrollUp元素的底部完全消失在视口上，则显示加购按钮
            if (productScrollUpBottom <= 0) {
                addToCartButton.classList.remove("hidden");
            } else {
                addToCartButton.classList.add("hidden");
            }
        }

        // 初始化时隐藏加购按钮
        addToCartButton.classList.add("hidden");

        // 监听滚动事件
        window.addEventListener("scroll", checkScroll);

    });
  </script>
  {% endif %}
    
  {%- liquid
    if product.selected_or_first_available_variant.featured_media
      assign seo_media = product.selected_or_first_available_variant.featured_media
    else
      assign seo_media = product.featured_media
    endif
  -%}

  <script type="application/ld+json">
    {
      "@context": "http://schema.org/",
      "@type": "Product",
      "name": {{ product.title | json }},
      "url": {{ request.origin | append: product.url | json }},
      {% if seo_media -%}
        "image": [
          {{ seo_media | image_url: width: 1920 | prepend: "https:" | json }}
        ],
      {%- endif %}
      "description": {{ product.description | strip_html | json }},
      {% if product.selected_or_first_available_variant.sku != blank -%}
        "sku": {{ product.selected_or_first_available_variant.sku | json }},
      {%- endif %}
      "brand": {
        "@type": "Brand",
        "name": {{ product.vendor | json }}
      },
      "offers": [
        {%- for variant in product.variants -%}
          {
            "@type" : "Offer",
            {%- if variant.sku != blank -%}
              "sku": {{ variant.sku | json }},
            {%- endif -%}
            {%- if variant.barcode.size == 12 -%}
              "gtin12": {{ variant.barcode }},
            {%- endif -%}
            {%- if variant.barcode.size == 13 -%}
              "gtin13": {{ variant.barcode }},
            {%- endif -%}
            {%- if variant.barcode.size == 14 -%}
              "gtin14": {{ variant.barcode }},
            {%- endif -%}
            "availability" : "http://schema.org/{% if variant.available %}InStock{% else %}OutOfStock{% endif %}",
            "price" : {{ variant.price | divided_by: 100.00 | json }},
            "priceCurrency" : {{ cart.currency.iso_code | json }},
            "url" : {{ request.origin | append: variant.url | json }}
          }{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      ]
    }
  </script>
</section>

{% javascript %}
  class ProductModal extends ModalDialog {
    constructor() {
      super();
    }

    hide() {
      super.hide();
      window.pauseAllMedia();
    }

    show(opener) {
      super.show(opener);
      this.showActiveMedia();
    }

    showActiveMedia() {
      const activeMedia = this.querySelector(`[data-media-id="${this.openedBy.getAttribute('data-media-id')}"]`);

      if (
        activeMedia.nodeName == 'DEFERRED-MEDIA' &&
        activeMedia.querySelector('template')?.content?.querySelector('.js-youtube')
      )
        activeMedia.loadContent();
    }
  }

  customElements.define('product-modal', ProductModal);
{% endjavascript %}

