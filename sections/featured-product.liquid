                      </svg>
                    </span>
                    <span>Free Delivery</span>
                  </div>
                </div>
                <div class="installment-wrapper" {{ block.shopify_attributes }}>
                  {%- assign product_form_installment_id = 'product-form-installment-' | append: section.id -%}
                  {%- form 'product', product, id: product_form_installment_id, class: 'installment caption-large' -%}
                    <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                    {{ form | payment_terms }}
                  {%- endform -%}
                </div>

              {%- when 'custom_badges' -%}
                {% if product.metafields.custom.badges != blank %}
                  <div class="product__block product__custom-badges">
                    {% if product.metafields.custom.badges.list? %}
                      {% for badge in product.metafields.custom.badges.value %}
                        <span class="badge badge--custom color-{{ settings.badge_custom_color_scheme }}" aria-hidden="true">
                          {% if settings.custom_icon != 'none' %}
                            <span class="icon--{{- settings.custom_icon_style }} icon--{{- settings.custom_icon_fill_type }}">
                              <i class="icon icon-pack icon-{{ settings.custom_icon }} {% if settings.custom_icon_style == 'colored' and settings.custom_icon_fill_type == 'gradient' %} text-gradient {% endif %}"></i>
                            </span>
                          {% endif %}
                          {{ badge }}
                        </span>
                      {% endfor %}
                    {% else %}
                      <span class="badge badge--custom color-{{ settings.badge_custom_color_scheme }}" aria-hidden="true">
                        {% if settings.custom_icon != 'none' %}
                          <span class="icon--{{- settings.custom_icon_style }} icon--{{- settings.custom_icon_fill_type }}">
                            <i class="icon icon-pack icon-{{ settings.custom_icon }} {% if settings.custom_icon_style == 'colored' and settings.custom_icon_fill_type == 'gradient' %} text-gradient {% endif %}"></i>
                          </span>
                        {% endif %}
                        {{ product.metafields.custom.badges }}
                      </span>
                    {% endif %}
                  </div>
                {% endif %}

              {%- when 'description' -%}
                {% if product.description != blank or block.settings.description != blank %}
                  <div class="product__block product__description" {{ block.shopify_attributes }}>
                    {% if block.settings.description != blank %}
                      {{- block.settings.description | escape -}}
                    {% else %}
                      {{- product.description -}}
                    {% endif %}
                  </div>
                {% endif %}

              {%- when 'inventory' -%}
                {% if product.selected_or_first_available_variant.inventory_management == 'shopify' %}
                  <div id="Inventory-{{ section.id }}" class="product__block product__inventory" {{ block.shopify_attributes }}>
                    <span class="product__inventory-inner product__inventory-inner--{% if product.selected_or_first_available_variant.inventory_quantity > 0 and product.selected_or_first_available_variant.inventory_quantity < 10 %}error{% elsif product.selected_or_first_available_variant.inventory_quantity == 0 %}empty{% endif %} bold">
                      {% if product.selected_or_first_available_variant.inventory_quantity >= 10 %}
                        {% render 'icon-check' %}
                        {{
                          'products.product.quantity.in_stock'
                          | t: quantity: product.selected_or_first_available_variant.inventory_quantity
                        }}
                      {% elsif product.selected_or_first_available_variant.inventory_quantity > 0
                        and product.selected_or_first_available_variant.inventory_quantity < 10
                      %}
                        {% render 'icon-bell' %}
                        {{
                          'products.product.quantity.in_stock'
                          | t: quantity: product.selected_or_first_available_variant.inventory_quantity
                        }}
                      {% elsif product.selected_or_first_available_variant.inventory_quantity == 0 %}
                        {% render 'icon-unavailable' %}
                        {{ 'products.product.quantity.out_of_stock' | t }}
                      {% endif %}
                    </span>
                  </div>
                {% endif %}

              {%- when 'variant_picker' -%}
              {% if product.has_only_default_variant != true %}
                <div class="product__block product-parameters">
                  {% unless product.has_only_default_variant %}
                    {% if block.settings.picker_type == 'button' or block.settings.picker_type == 'image' %}
                      <variant-radios
                        id="variant-radios-{{ section.id }}"
                        class="no-js-hidden featured-product-radios"
                        data-section="{{ section.id }}"
                        data-url="{{ product.url }}"
                        {{ block.shopify_attributes }}
                      >
                        {%- for option in product.options_with_values -%}
                          {% liquid
                            assign color_trigger = settings.trigger_swatch | handle | strip
                            assign name_option = option.name | handle | strip
                          %}

                          <fieldset
                            class="product-form__controls product-form__controls--{% if settings.show_color_swatch and color_trigger == name_option %}colors{% endif %}"
                            id="SingleOptionSelector-{{ forloop.index0 }}"
                          >
                            {% comment %}
                              <legend class="product-form__group-name subtitle">
                                {{ option.name }}:
                                {% if settings.show_color_swatch and color_trigger == name_option %}
                                  <span id="ColorName-{{ section.id }}">{{ option.selected_value }}</span>
                                {% endif %}
                              </legend>
                            {% endcomment %}
                            <div class="product-form__controls-group">
                              <div class="variant-options-title">
                                {{ option.name }}:
                                {% if settings.show_color_swatch and color_trigger == name_option %}
                                  <span id="ColorName-{{ section.id }}">{{ option.selected_value }}</span>
                                {% endif -%}
                              </div>
                              <div class="variant-options-wrapper">
                                {%- render 'product-variant-options', product: product, option: option, block: block %}
                              </div>
                            </div>
                          </fieldset>
                        {%- endfor -%}

                        <script type="application/json">
                          {{ product.variants | json }}
                        </script>
                      </variant-radios>
                    {% else %}
                      {% liquid
                        assign color_trigger = settings.trigger_swatch | handle | strip
                        assign name_option = option.name | handle | strip
                      %}
                      <variant-selects
                        id="variant-selects-{{ section.id }}"
                        class="no-js-hidden"
                        data-section="{{ section.id }}"
                        data-url="{{ product.url }}"
                        {{ block.shopify_attributes }}
                      >
                        {%- for option in product.options_with_values -%}
                          {% liquid
                            assign color_trigger = settings.trigger_swatch | handle | strip
                            assign name_option = option.name | handle | strip
                          %}

                          {% if settings.show_color_swatch == false or color_trigger != name_option %}
                            <fieldset class="product-form__controls">
                              <label
                                for="Option-{{ section.id }}-{{ forloop.index0 }}"
                                class="product-form__group-name subtitle"
                              >
                                {{ option.name }}:
                                {% if settings.show_color_swatch and color_trigger == name_option %}
                                  <span id="ColorName-{{ section.id }}">{{ option.selected_value }}</span>
                                {% endif %}
                              </label>
                              <div class="product-form__controls-group">
                                <div class="select">
                                  <select
                                    name="options[{{ option.name | escape }}]"
                                    id="Option-{{ section.id }}-{{ forloop.index0 }}"
                                    class="select__select"
                                    form="{{ product_form_id }}"
                                  >
                                    {% render 'product-variant-options',
                                      product: product,
                                      option: option,
                                      block: block
                                    %}
                                  </select>
                                  {% render 'icon-caret' %}
                                </div>
                              </div>
                            </fieldset>
                          {% elsif settings.show_color_swatch and color_trigger == name_option %}
                            {% if color_trigger != name_option %}
                              <fieldset class="product-form__controls">
                                <label
                                  for="Option-{{ section.id }}-{{ forloop.index0 }}"
                                  class="product-form__group-name subtitle"
                                >
                                  {{ option.name }}:
                                  {% if settings.show_color_swatch and color_trigger == name_option %}
                                    <span id="ColorName-{{ section.id }}">{{ option.selected_value }}</span>
                                  {% endif %}
                                </label>
                                <div class="product-form__controls-group">
                                  <div class="select">
                                    <select
                                      name="options[{{ option.name | escape }}]"
                                      id="Option-{{ section.id }}-{{ forloop.index0 }}"
                                      class="select__select"
                                      form="{{ product_form_id }}"
                                    >
                                      {% render 'product-variant-options',
                                        product: product,
                                        option: option,
                                        block: block
                                      %}
                                    </select>
                                    {% render 'icon-caret' %}
                                  </div>
                                </div>
                              </fieldset>
                            {% else %}
                              <fieldset
                                class="product-form__controls js-radio-colors"
                                id="SingleOptionSelector-{{ forloop.index0 }}"
                              >
                                <legend class="product-form__group-name subtitle">
                                  {{ option.name }}:
                                  {% if settings.show_color_swatch and color_trigger == name_option %}
                                    <span id="ColorName-{{ section.id }}">{{ option.selected_value }}</span>
                                  {% endif %}
                                </legend>
                                <div class="product-form__controls-group">
                                  {% render 'product-variant-options', product: product, option: option, block: block %}
                                </div>
                              </fieldset>
                            {% endif %}
                          {% endif %}
                        {% endfor %}
                        <script type="application/json">
                          {{ product.variants | json }}
                        </script>
                      </variant-selects>
                    {% endif %}
                  {% endunless %}

                  <noscript class="product-form__noscript-wrapper-{{ section.id }}">
                    <fieldset class="product-form__controls {% if product.has_only_default_variant %} hidden{% endif %}">
                      <label for="Variants-{{ section.id }}" class="product-form__group-name subtitle">
                        {{- 'products.product.product_variants' | t -}}
                        :</label
                      >
                      <div class="product-form__controls-group">
                        <div class="select">
                          <select
                            name="id"
                            id="Variants-{{ section.id }}"
                            class="select__select"
                            form="{{ product_form_id }}"
                          >
                            {%- for variant in product.variants -%}
                              <option
                                {% if variant == product.selected_or_first_available_variant %}
                                  selected="selected"
                                {% endif %}
                                {% if variant.available == false %}
                                  disabled
                                {% endif %}
                                value="{{ variant.id }}"
                              >
                                {%- liquid
                                  echo variant.title
                                  if settings.currency_code_enabled
                                    echo variant.price | money_with_currency | strip_html | prepend: ' - '
                                  else
                                    echo variant.price | money | strip_html | prepend: ' - '
                                  endif
                                  if variant.available == false
                                    echo 'products.product.sold_out' | t | prepend: ' - '
                                  endif
                                  if variant.quantity_rule.increment > 1
                                    echo 'products.product.quantity.multiples_of' | t: quantity: variant.quantity_rule.increment | prepend: ' - '
                                  endif
                                  if variant.quantity_rule.min > 1
                                    echo 'products.product.quantity.minimum_of' | t: quantity: variant.quantity_rule.min | prepend: ' - '
                                  endif
                                  if variant.quantity_rule.max != null
                                    echo 'products.product.quantity.maximum_of' | t: quantity: variant.quantity_rule.max | prepend: ' - '
                                  endif
                                  assign cart_quantity = cart | item_count_for_variant: variant.id
                                  if cart_quantity > 0
                                    echo 'products.product.quantity.in_cart_html' | t: quantity: cart_quantity | prepend: ' - '
                                  endif
                                -%}
                              </option>
                            {%- endfor -%}
                          </select>
                          {% render 'icon-caret' %}
                        </div>
                      </div>
                    </fieldset>
                  </noscript>
                </div>
              {% endif %}


              {%- when 'buy_buttons' -%}
                <div class="product__block product__buy-buttons" {{ block.shopify_attributes }}>
                  <style>
                  :root {
                    --submit-btn-color:{{ block.settings.color }};--submit-btn-bg:{{ block.settings.bg_color }};
                  }
                  </style>
                  {%- liquid
                    assign gift_card_recipient_feature_active = false
                    if block.settings.show_gift_card_recipient and product.gift_card?
                      assign gift_card_recipient_feature_active = true
                    endif
  
                    assign show_dynamic_checkout = false
                    if block.settings.show_dynamic_checkout and gift_card_recipient_feature_active == false
                      assign show_dynamic_checkout = true
                    endif
                  -%}
  
                  <product-form class="product-form" data-hide-errors="{{ gift_card_recipient_feature_active }}">
                    <div class="product-form__error-message-wrapper" role="alert" hidden>
                      <svg
                        aria-hidden="true"
                        focusable="false"
                        role="presentation"
                        class="icon icon-error"
                        viewBox="0 0 13 13"
                      >
                        <circle cx="6.5" cy="6.50049" r="5.5" stroke="white" stroke-width="2"/>
                        <circle cx="6.5" cy="6.5" r="5.5" fill="#EB001B" stroke="#EB001B" stroke-width="0.7"/>
                        <path d="M5.87413 3.52832L5.97439 7.57216H7.02713L7.12739 3.52832H5.87413ZM6.50076 9.66091C6.88091 9.66091 7.18169 9.37267 7.18169 9.00504C7.18169 8.63742 6.88091 8.34917 6.50076 8.34917C6.12061 8.34917 5.81982 8.63742 5.81982 9.00504C5.81982 9.37267 6.12061 9.66091 6.50076 9.66091Z" fill="white"/>
                        <path d="M5.87413 3.17832H5.51535L5.52424 3.537L5.6245 7.58083L5.63296 7.92216H5.97439H7.02713H7.36856L7.37702 7.58083L7.47728 3.537L7.48617 3.17832H7.12739H5.87413ZM6.50076 10.0109C7.06121 10.0109 7.5317 9.57872 7.5317 9.00504C7.5317 8.43137 7.06121 7.99918 6.50076 7.99918C5.94031 7.99918 5.46982 8.43137 5.46982 9.00504C5.46982 9.57872 5.94031 10.0109 6.50076 10.0109Z" fill="white" stroke="#EB001B" stroke-width="0.7"/>
                      </svg>
                      <span class="product-form__error-message"></span>
                    </div>
                    {%- form 'product',
                      product,
                      id: product_form_id,
                      class: 'form',
                      novalidate: 'novalidate',
                      data-type: 'add-to-cart-form'
                    -%}
                      <input
                        type="hidden"
                        name="id"
                        value="{{ product.selected_or_first_available_variant.id }}"
                        {% if product.selected_or_first_available_variant.available == false %}
                          disabled
                        {% endif %}
                      >
                      {%- if gift_card_recipient_feature_active -%}
                        {%- render 'gift-card-recipient-form', product: product, form: form, section: section -%}
                      {%- endif -%}
  
                      <div class="product-form__buttons a123">
                        <div class="product-form__buttons-row">
                          {% if block.settings.show_quantity %}
                            <div
                              class="product-form__input product-form__quantity no-js-hidden"
                              {{ block.shopify_attributes }}
                            >
                              {%- assign cart_qty = cart
                                | item_count_for_variant: product.selected_or_first_available_variant.id
                              -%}
                              <quantity-input class="quantity">
                                <button class="quantity__button no-js-hidden focus-inset" name="minus" type="button">
                                  <span class="visually-hidden">
                                    {{- 'products.product.quantity.decrease' | t: product: product.title | escape -}}
                                  </span>
                                  {% render 'icon-minus' %}
                                </button>
                                <input
                                  class="quantity__input focus-inset"
                                  type="number"
                                  name="quantity"
                                  id="Quantity-{{ section.id }}"
                                  data-cart-quantity="{{ cart_qty }}"
                                  data-min="{{ product.selected_or_first_available_variant.quantity_rule.min }}"
                                  min="{{ product.selected_or_first_available_variant.quantity_rule.min }}"
                                  {% if product.selected_or_first_available_variant.quantity_rule.max != null %}
                                    data-max="{{ product.selected_or_first_available_variant.quantity_rule.max }}"
                                    max="{{ product.selected_or_first_available_variant.quantity_rule.max }}"
                                  {% endif %}
                                  step="{{ product.selected_or_first_available_variant.quantity_rule.increment }}"
                                  value="{{ product.selected_or_first_available_variant.quantity_rule.min }}"
                                  form="{{ product_form_id }}"
                                >
                                <label class="visually-hidden" for="Quantity-{{ section.id }}">
                                  {{ 'products.product.quantity.label' | t }}
                                </label>
                                <button class="quantity__button no-js-hidden focus-inset" name="plus" type="button">
                                  <span class="visually-hidden">
                                    {{- 'products.product.quantity.increase' | t: product: product.title | escape -}}
                                  </span>
                                  {% render 'icon-plus' %}
                                </button>
                              </quantity-input>
                              <div class="quantity__rules caption">
                                {%- if product.selected_or_first_available_variant.quantity_rule.increment > 1 -%}
                                  <span class="divider">
                                    {{-
                                      'products.product.quantity.multiples_of'
                                      | t: quantity: product.selected_or_first_available_variant.quantity_rule.increment
                                    -}}
                                  </span>
                                {%- endif -%}
                                {%- if product.selected_or_first_available_variant.quantity_rule.min > 1 -%}
                                  <span class="divider">
                                    {{-
                                      'products.product.quantity.minimum_of'
                                      | t: quantity: product.selected_or_first_available_variant.quantity_rule.min
                                    -}}
                                  </span>
                                {%- endif -%}
                                {%- if product.selected_or_first_available_variant.quantity_rule.max != null -%}
                                  <span class="divider">
                                    {{-
                                      'products.product.quantity.maximum_of'
                                      | t: quantity: product.selected_or_first_available_variant.quantity_rule.max
                                    -}}
                                  </span>
                                {%- endif -%}
                              </div>
                            </div>
                          {% endif %}
  
                          <button
                            type="submit"
                            name="add"
                            class="product-form__submit lie button button--{%- if show_dynamic_checkout -%}tertiary{% else %}primary{%- endif -%}"
                            {% if product.selected_or_first_available_variant.available == false %}
                              disabled
                            {% endif %}
                            data-variantstrings-addtocart="{% if block.settings.buy_text != blank %}{{ block.settings.buy_text }} {% else %} Shop Now at {{ product.price | money |  replace: ".00", "" }} {% endif %}"
                          >
                            {%- if product.selected_or_first_available_variant.available -%}
                              <span>
                                {% if block.settings.buy_text != blank %}{{ block.settings.buy_text }} {% else %} Shop Now at {{ product.price | money |  replace: ".00", "" }} {% endif %}
                              </span>
                              <div class="loading-overlay__spinner hidden">
                                {%- render 'icon-loading' -%}
                              </div>
                            {%- else -%}
                              <span>
                                {{ 'products.product.sold_out' | t }}
                              </span>
                            {%- endif -%}
                          </button>
  
                          {% if block.settings.show_amazon_btn and product.metafields.custom.custom_amazon_link != blank %}
                              <a href="{{ product.metafields.custom.custom_amazon_link }}" class="button amazon_btn button--tertiary"><span>{{ block.settings.amazon_btn_label }}</span></a>
                          {% endif %}
                          
                        </div>
  
                        <div class="product-form__checkout no-js-hidden">
                          {%- if show_dynamic_checkout -%}
                            {{ form | payment_button }}
                          {%- endif -%}
                        </div>
                      </div>
                    {%- endform -%}
                  </product-form>
                </div>

              {%- when 'amazon_btn' -%}
                {%- if product.metafields.custom.custom_amazon_link != blank -%}
                  <div class="product__block amazon_btn_block">
                    <a href="{{ product.metafields.custom.custom_amazon_link }}" style="background-color: {{ block.settings.bg_color }}; color: {{ block.settings.color }};" class="button amazon_btn button--tertiary">
                      <span>{{ block.settings.amazon_btn_label }}</span>
                    </a>
                  </div>
                {%- endif -%}
  
              {% when 'text_with_icon' %}
                <div class="product__block product__text-icons" {{ block.shopify_attributes }}>
                  <div class="product__text-icons-wrapper">
                    {% if block.settings.show_text_with_icon_1 %}
                    <div class="product__text-item h6">
                      {% if block.settings.icon_1 != 'none' %}
                        <div class="product__text-icon {% if block.settings.box_shadow %}product__text-icon--shadow{% endif %} product__text-icon--{{- block.settings.icon_style }} product__text-icon--{{- block.settings.icon_fill_type }}">
                          <i
                            class="icon icon-pack icon-{{ block.settings.icon_1 }} {% if block.settings.icon_style == 'colored' and block.settings.icon_fill_type == 'gradient' %} text-gradient {% endif %}"
                          ></i>
                        </div>
                      {% endif %}
                      {{ block.settings.text_1 }}
                    </div>
                    {% endif %}

                    {% if block.settings.show_text_with_icon_2 %}
                    <div class="product__text-item h6">
                      {% if block.settings.icon_2 != 'none' %}
                        <div class="product__text-icon {% if block.settings.box_shadow %}product__text-icon--shadow{% endif %} product__text-icon--{{- block.settings.icon_style }} product__text-icon--{{- block.settings.icon_fill_type }}">
                          <i
                            class="icon icon-pack icon-{{ block.settings.icon_2 }} {% if block.settings.icon_style == 'colored' and block.settings.icon_fill_type == 'gradient' %} text-gradient {% endif %}"
                          ></i>
                        </div>
                      {% endif %}
                      {{ block.settings.text_2 }}
                    </div>
                    {% endif %}

                    {% if block.settings.show_text_with_icon_3 %}
                    <div class="product__text-item h6">
                      {% if block.settings.icon_3 != 'none' %}
                        <div class="product__text-icon {% if block.settings.box_shadow %}product__text-icon--shadow{% endif %} product__text-icon--{{- block.settings.icon_style }} product__text-icon--{{- block.settings.icon_fill_type }}">
                          <i
                            class="icon icon-pack icon-{{ block.settings.icon_3 }} {% if block.settings.icon_style == 'colored' and block.settings.icon_fill_type == 'gradient' %} text-gradient {% endif %}"
                          ></i>
                        </div>
                      {% endif %}
                      {{ block.settings.text_3 }}
                    </div>
                    {% endif %}

                    {% if block.settings.show_text_with_icon_4 %}
                    <div class="product__text-item h6">
                      {% if block.settings.icon_4 != 'none' %}
                        <div class="product__text-icon {% if block.settings.box_shadow %}product__text-icon--shadow{% endif %} product__text-icon--{{- block.settings.icon_style }} product__text-icon--{{- block.settings.icon_fill_type }}">
                          <i
                            class="icon icon-pack icon-{{ block.settings.icon_4 }} {% if block.settings.icon_style == 'colored' and block.settings.icon_fill_type == 'gradient' %} text-gradient {% endif %}"
                          ></i>
                        </div>
                      {% endif %}
                      {{ block.settings.text_4 }}
                    </div>
                    {% endif %}
              
                  </div>
                </div>

              {%- when 'pickup_availability' -%}
                {%- assign pick_up_availabilities = product.selected_or_first_available_variant.store_availabilities
                  | where: 'pick_up_enabled', true
                -%}
                {%- if pick_up_availabilities.size > 0 -%}
                  <div class="product__block pickup-availability" {{ block.shopify_attributes }}>
                    {{ 'component-pickup-availability.css' | asset_url | stylesheet_tag }}

                    <pickup-availability
                      class="product__pickup-availabilities no-js-hidden"
                      {% if product.selected_or_first_available_variant.available and pick_up_availabilities.size > 0 %}
                        available
                      {% endif %}
                      data-base-url="{{ shop.url }}{{ routes.root_url }}"
                      data-variant-id="{{ product.selected_or_first_available_variant.id }}"
                      data-has-only-default-variant="{{ product.has_only_default_variant }}"
                    >
                      <template>
                        <pickup-availability-preview class="pickup-availability-preview">
                          {% render 'icon-unavailable' %}
                          <div class="pickup-availability-info">
                            <p class="caption-large">{{ 'products.product.pickup_availability.unavailable' | t }}</p>
                            <button class="pickup-availability-button button button--simple">
                              <span>{{ 'products.product.pickup_availability.refresh' | t }}</span>
                            </button>
                          </div>
                        </pickup-availability-preview>
                      </template>
                    </pickup-availability>
                    <script src="{{ 'pickup-availability.js' | asset_url }}" defer="defer"></script>
                  </div>
                {%- endif -%}

              {%- when 'Gift_Box' -%}
                <style>
                  .gift-box {
                      border: 1px solid #b2b2b2;
                      border-radius: 10px;
                      padding: 2rem;
                  }
                  .gift_box + .gift_box {
                      border-top: 1px solid #aaa;
                      padding-top: 10px;
                      margin-top: 10px;
                  }
                  .gift-box-image{
                    width: 60px;
                  }
                  .gift-box-heading {
                      font-size: 20px;
                      font-weight: bold;
                      margin-bottom: 10px;
                      color: #000;
                  }
                  .gift-box-title {
                      margin: 0 0 5px 0;
                      color:{{ block.settings.siez_color }} ;
                      font-size: 18px;
                  } 

                  .gift-box-price {
                    color:{{ block.settings.siez_color }} ; 
                      font-size: 20px;
                  }
                  .gift-box-price .price-at {
                      opacity: 0.5;
                      text-decoration: line-through;
                      margin-left: 10px;
                  }
                  span.price-zore {
                      font-weight: bold;
                  }
                  /* Hide the default checkbox */
                    .gift-box_label input[type="checkbox"] {
                        display: none;
                    }

                    /* Custom checkbox styling */
                    .gift-box_label {
                        position: relative;
                        display: inline-block;
                        cursor: pointer;
                    }

                    .custom-checkbox {
                      width: 3rem;
                      height: 3rem;
                      border: 2px solid #000;
                      border-radius: 3px;
                      display: inline-block;
                      background-color: #fff;
                      transition: all 0.3s ease;
                    }

                    /* When checkbox is checked */
                    .gift-box_label input[type="checkbox"]:checked + .custom-checkbox {
                        background-color: rgba(var(--color-button)); /* Green background when checked */
                        border-color: var(--color-button);
                        transform: scale(1.2); /* Animate scaling */
                    }

                    /* Add checkmark when checked */
                    .gift-box_label input[type="checkbox"]:checked + .custom-checkbox::before {
                      content: '';
                      position: absolute;
                      left: 0.8rem;
                      top: 0.2rem;
                      width: 1rem;
                      height: 1.5rem;
                      border: solid white;
                      border-width: 0 2px 2px 0;
                      transform: rotate(45deg);
                    }
                    .gift_box{
                      display: flex;
                      align-items: center;
                      justify-content: space-between;
                    }
                    /* Hover effect */
                    .gift-box_label:hover .custom-checkbox {
                        border-color: var(--color-button);
                    }
                    .gift-box_bing h4{
                        margin: 0 0 1rem 0;
                    }
                    .gift-box_bing ul li{
                        list-style-type:none;
                        color: {{ block.settings.siez_color }};
                    }
                    .gift-box_bing ul{
                        margin: 0;
                        padding: 0;
                    }
                </style>
                {% comment %} 加购动作在product-form.js里完成 {% endcomment %}
                {% if product.metafields.custom._GiftBox != blank %}
                  <div class="product__block gift-box">
                    <div class="gift-box-heading">{{ block.settings.heading }}</div>
                    
                    <div class="gift_box-area">
                      {% assign checked_total = block.settings.gift_item_checked | times:1 %}
                      {% for giftbox_product in product.metafields.custom._GiftBox.value %}
                        <div class="gift_box">
                          <label class="gift-box_label">
                            <input type="checkbox" class="gift-box-checkbox" value="{{ giftbox_product.selected_or_first_available_variant.id }}" {% if forloop.index <= checked_total %}checked{% endif %}>
                            <span class="custom-checkbox"></span>
                          </label>
                          <div style="width: 55%;">
                            <p class="gift-box-title">
                              {{ giftbox_product.title }}
                            </p>
                            {% if giftbox_product.price %}
                              <div class="gift-box-price">
                                <span class="price-zore">{{ '0' | money | replace:'.00', '' }}</span>
                                <span class="price-at">{{ giftbox_product.price | money }}</span>
                              </div>
                            {% endif %}
                          </div>
                          {% if giftbox_product.featured_image %}
                            <img
                              class="gift-box-image"
                              src="{{ giftbox_product.featured_image | img_url: 'medium' }}"
                              alt="{{ giftbox_product.title }}"
                            >
                          {% endif %}
                        </div>
                      {% endfor %}
                    </div>
                  </div>
                {% endif %}

              
              {%- when 'custom_liquid' -%}
                <div class="product__block custom-liquid" {{ block.shopify_attributes }}>
                  {{ block.settings.custom_liquid }}
                </div>

              {%- when 'payment_enable' -%}
                  {%- if block.settings.payment_enable -%}
                    <style>
                      .product_payment_text{
                        font-size: 2rem;
                        font-weight: 500;
                        margin-bottom: 1rem;
                      }
                      .product_payment_enable_ul{
                        display: flex;
                        flex-wrap: wrap;
                        gap: 0.5rem;
                        margin: 0;
                        padding: 0;
                      }
                      .product_payment_enable_li{
                        border-radius: 1.2rem;
                        list-style-type: none;
                        box-sizing: border-box;
                      }
                      .product_payment_enable_li svg{
                        width: 4.5rem;
                        height: 3rem;
                      }
                      @media(max-width: 768px) {
                        .product_payment_enable{
                            display: block;
                        }
                        .product_payment_text{
                            width: 100%;
                            margin: 0 0 1rem 0;
                        }
                        .product_payment_enable_ul{
                            width: 100%;
                            margin: 0;
                        }
                      }
                    </style>
                    <div class="product__block footer__column footer__column--payment">
                      <div class="product_payment_enable">
                        <div class="product_payment_text">{{ block.settings.payment_label }}</div>
                        <ul class="product_payment_enable_ul" role="list">
                          {%- for type in shop.enabled_payment_types -%}
                            <li class="product_payment_enable_li">
                              {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
                            </li>
                          {%- endfor -%}
                        </ul>
                      </div>
                    </div>
                  {%- endif -%}




                {%- when 'product_featured_info' -%}

                  {% if product.metafields.custom.product_featured_info != blank %}
                    <div class="product__block product_featured_info">
                      <ul class="feature-list">
                        {% if product.metafields.custom.product_featured_info.list? %}
                          {% for feature in product.metafields.custom.product_featured_info.value %}
                            <li class="feature-item">{{ feature | strip }}</li>
                          {% endfor %}
                        {% endif %}
                      </ul>
                    </div>
                  {% endif %}

                {%- when 'limited_time_gift' -%}
                  {% comment %} 加购动作在product-form.js里完成 {% endcomment %}
                  {% if product.metafields.custom._GiftBox != blank %}
                    <div class="product__block limited_time_gift">
                      <div class="gift-box-heading">{{ block.settings.heading }}</div>
                      
                      <div class="gift_box-area">
                        {% for giftbox_product in product.metafields.custom._GiftBox.value %}
                          <div class="gift_box">
                            <input type="checkbox" class="hidden gift-box-checkbox" value="{{ giftbox_product.selected_or_first_available_variant.id }}" checked />
                            <span class="gift-box-title">{{ giftbox_product.title }}</span>
                            <div class="gift-box-price">
                              <span class="price-at">{{ giftbox_product.price | money }}</span>
                              <span class="price-zore">{{ '0' | money | replace:'.00', '' }}</span>
                            </div>
                          </div>
                        {% endfor %}
                      </div>
                    </div>
                  {% endif %}
                    
    
                {%- when 'service_icon' -%}
                  <div class="product__block service_icon">
                    <div class="service_icon-items">
                      {% for i in (1..3) %}
                        {% capture text %}text{{ i }}{% endcapture %}
                        {% capture service_icon %}service_icon{{ i }}{% endcapture %}
                      
                        {% if block.settings[text] != blank and block.settings[service_icon] != blank %}
                        <div class="icon-item">
                          <div class="icon"><img src="{{ block.settings[service_icon] |  image_url: width: 200 }}" width="auto" height="auto" /></div>
                          <div class="text">{{ block.settings[text] }}</div>
                        </div>
                        {% endif %}
                      {% endfor %}
                    </div>
                  </div>


              {%- when '@app' -%}
                {% render block %}
            {%- endcase -%}
          {%- endfor -%}
        {% else %}
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'title' -%}
                <div
                  class="
                    product__title__wrapper
                    {%- if product.available == false %} price--sold-out {% endif -%}
                    {%- if product.compare_at_price > product.price %} price--on-sale {% endif -%}
                  "
                >
                  <h1 class="product__title {{ block.settings.heading_size }}" {{ block.shopify_attributes }}>
                    {{ 'products.product.product_heading' | t }}
                  </h1>
                </div>
              {%- when 'price' -%}
                <div class="no-js-hidden price-wrapper" id="price-{{ section.id }}" {{ block.shopify_attributes }}>
                  {% render 'price' %}
                </div>
            {% endcase %}
          {% endfor %}
        {% endif %}
        {% if section.settings.product_item != blank and section.settings.show_details_link %}
          <a href="{{ product.url }}" target="_blank" class="button button--simple button--arrow product__full-details">
            <span>{{ 'general.card.view__more' | t }}</span>
            {% render 'icon-button-arrow' %}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</div>

<script type="application/ld+json">
      {
        "@context": "http://schema.org/",
        "@type": "Product",
        "name": {{ product.title | json }},
        "url": {{ request.origin | append: product.url | json }},
        {% if seo_media -%}
          "image": [
            {{ seo_media | image_url: width: 1920 | prepend: "https:" | json }}
          ],
        {%- endif %}
        "description": {{ product.description | strip_html | json }},
        {% if product.selected_or_first_available_variant.sku != blank -%}
          "sku": {{ product.selected_or_first_available_variant.sku | json }},
        {%- endif %}
        "brand": {
          "@type": "Brand",
          "name": {{ product.vendor | json }}
        },
        "offers": [
          {%- for variant in product.variants -%}
            {
              "@type" : "Offer",
              {%- if variant.sku != blank -%}
                "sku": {{ variant.sku | json }},
              {%- endif -%}
  {%- if variant.barcode.size == 12 -%}
                "gtin12": {{ variant.barcode }},
              {%- endif -%}
  {%- if variant.barcode.size == 13 -%}
                "gtin13": {{ variant.barcode }},
              {%- endif -%}
  {%- if variant.barcode.size == 14 -%}
                "gtin14": {{ variant.barcode }},
              {%- endif -%}
              "availability" : "http://schema.org/{% if variant.available %}InStock{% else %}OutOfStock{% endif %}",
              "price" : {{ variant.price | divided_by: 100.00 | json }},
              "priceCurrency" : {{ cart.currency.iso_code | json }},
              "url" : {{ request.origin | append: variant.url | json }}
            }{% unless forloop.last %},{% endunless %}
  	{%- endfor -%}
        ]
      }
</script>

{%- if first_3d_model -%}
  <script type="application/json" id="ProductJSON-{{ product.id }}">
    {{ product.media | where: 'media_type', 'model' | json }}
  </script>

  <script src="{{ 'product-model.js' | asset_url }}" defer></script>
{%- endif -%}

