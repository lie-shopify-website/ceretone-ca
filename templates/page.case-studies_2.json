        "custom_liquid_text": "",
        "custom_liquid": "<section class=\"aarp-banner\">\n  <div class=\"aarp-banner__inner\">\n    <h1 class=\"aarp-banner__title\">\n      <span class=\"highlight\">Exclusive AARP</span> Member Offer\n    </h1>\n\n    <h2 class=\"aarp-banner__subtitle\">\n      As an <span class=\"highlight\">AARP member</span>, you qualify for special pricing on Core One Pro hearing aids.\n    </h2>\n  </div>\n</section>\n\n<style>\n/* ===== Full-width banner ===== */\n.aarp-banner {\n  width: 100%;\n  background: linear-gradient(\n    180deg,\n    #FFFEFB 0%,\n    #FFF4EC 100%\n  );\n}\n\n/* ===== Inner container ===== */\n.aarp-banner__inner {\n  max-width: 1400px;\n  margin: 0 auto;\n  padding: 50px 0;\n  text-align: center;\n}\n\n/* ===== Title ===== */\n.aarp-banner__title {\n  font-family: Helvetica, Arial, sans-serif;\n  font-size: 30px;\n  line-height: 1.2;\n  font-weight: 700;\n  color: #000;\n  margin: 0 0 10px;\n}\n\n/* ===== Subtitle ===== */\n.aarp-banner__subtitle {\n  font-family: Helvetica, Arial, sans-serif;\n  font-size: 24px;\n  line-height: 1.4;\n  font-weight: 400;\n  color: #524842;\n  margin: 0;\n}\n\n/* ===== Highlight ===== */\n.aarp-banner .highlight {\n  color: #EC1300;\n  font-weight: 600;\n}\n\n/* ===== Stronger highlight in title only ===== */\n.aarp-banner__title .highlight {\n  font-weight: 700;\n}\n\n/* ===== Mobile only: extra bottom space ===== */\n@media (max-width: 768px) {\n  .aarp-banner__inner {\n    max-width: 335px;\n    padding: 25px 0 90px;\n  }\n\n  .aarp-banner__title {\n    font-size: 24px;\n  }\n\n  .aarp-banner__subtitle {\n    font-size: 18px;\n  }\n}\n</style>"
