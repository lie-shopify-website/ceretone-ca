    "collapsible_content_L7C9i7": {
      "type": "collapsible-content",
      "blocks": {
        "accordion_rq9UeK": {
          "type": "accordion",
          "settings": {
            "question": "Is Solid a hearing aid or a sound amplifier?",
            "answer": "<p>Solid is an <strong>FDA-registered OTC (Over-the-Counter) hearing aid </strong>designed for mild to moderate hearing loss. Unlike basic amplifiers, it uses <strong>smart noise reduction</strong>, <strong>scene-specific sound processing</strong>, and <strong>medical-grade amplification </strong>to enhance clarity, not just volume.</p>",
            "opened": true
          }
        },
        "accordion_MxtPUb": {
          "type": "accordion",
          "settings": {
            "question": "What’s the actual battery life?",
            "answer": "<ul><li><strong>Single Charge</strong>: <strong>2.5 hours to fully charge</strong>, providing <strong>up to 20 hours</strong> of use.</li><li><strong>Charging Case</strong>: The case is used only for storing and charging the hearing aids via a charging cable; it does not function as a power bank and cannot charge the hearing aids independently.</li></ul><p><em><strong>Note</strong></em><em>: Actual battery life may vary based on volume settings and mode selection.</em></p>",
            "opened": false
          }
        },
        "accordion_iH96hA": {
          "type": "accordion",
          "settings": {
            "question": "How do I adjust volume or switch programs?",
            "answer": "<p><strong>Easy tactile controls</strong>:</p><ul><li><strong>Volume</strong>: Use the switch to adjust the volume up or down.</li><li><strong>Programs</strong>: Hold the switch for 3 seconds to cycle through <strong>Normal, Restaurant, Outdoor, and Music.</strong></li><li>With the <strong>beep</strong> indicating volume or mode changes. No apps or complex menus are required!</li></ul>",
            "opened": false
          }
        },
        "accordion_ACDykh": {
          "type": "accordion",
          "settings": {
            "question": "Will Solid fit my ears comfortably?",
            "answer": "<ul><li><strong>Ear Tips</strong>: Comes with three sizes: <strong>S</strong>, <strong>M</strong>, and <strong>L</strong> (soft silicone).</li><li><strong>Lightweight Design</strong>: Each earpiece weighs only <strong>3 g</strong> (＜0.01 lb) for all-day comfort.</li><li><strong>60-Day Risk-Free Trial</strong>: Try it worry-free. Return it if you’re not satisfied and without any extra fees.</li></ul>",
            "opened": false
          }
        },
        "accordion_bRjLYW": {
          "type": "accordion",
          "settings": {
            "question": "How does noise reduction work?",
            "answer": "<p>Solid’s <strong>Smart Acoustic Chip</strong> automatically:</p><ul><li>Reduces background noise (e.g., wind, chatter).</li><li>Enhances speech and music clarity.</li><li>Adapts to environments (e.g., <strong>Restaurant Mode</strong> cuts 50% of ambient noise).</li></ul>",
            "opened": false
          }
        },
        "accordion_tV9Hmp": {
          "type": "accordion",
          "settings": {
            "question": "Can I connect Solid to my phone or TV via Bluetooth?",
            "answer": "<p>Solid focuses on <strong>direct sound enhancement </strong>for simplicity and affordability. It does <strong>not </strong>support Bluetooth—ideal for users prioritizing ease of use over wireless features.</p><p><em><strong>Tip</strong></em><em>: If Bluetooth functionality is important to you, consider </em><a href=\"/products/beacon-otc-hearing-aids\" title=\"Beacon OTC Hearing Aids\"><em><strong>Beacon</strong></em></a><em>, which offers wireless connectivity.</em></p>",
            "opened": false
          }
        }
      },
