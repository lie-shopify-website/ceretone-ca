    "custom_liquid_yzr8hn": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid_text": "",
        "custom_liquid": "<style>\n    .Logisticsinquiry {\n        padding: 15rem 0;\n        background: #F5F5F5;\n    }\n\n    .Logisticsinquiry_box {\n        display: flex;\n        justify-content: center;\n    }\n\n    .Logisticsinquiry_h2 {\n        margin: 0 0 5rem;\n        text-align: center;\n    }\n\n    .Logisticsinquiry_box_input {\n\n        padding: 0.5rem;\n        background: #FFFFFF;\n        box-shadow: 0px 0px 14px 0px rgba(0, 0, 0, 0.5);\n        border-radius: 1.1rem;\n    }\n\n    .Logisticsinquiry_box_input_text {\n        border: 0;\n        padding: 1rem;\n        width: 35rem;\n        height: 5rem;\n        line-height: 5rem;\n        font-size: 1.6rem;\n    }\n\n    .Logisticsinquiry_box_input_btn {\n        background-color: #1462D7;\n        color: #FFFFFF;\n        border-radius: 0.5rem;\n        border: 0;\n        padding: 0 3rem;\n        font-size: 1.8rem;\n        font-weight: 700;\n        height: 5rem;\n        line-height: 5rem;\n        cursor: pointer;\n        transition: background-color 0.3s, color 0.3s;\n    }\n\n    .Logisticsinquiry_box_input_btn:hover {\n        background-color: #1462D7;\n        color: #FFFFFF;\n    }\n\n    .Logisticsinquiry_box_input_text::placeholder {\n        color: gray;\n        /* Adjust the color to your preference */\n    }\n\n    @media(max-width: 768px) {\n        .Logisticsinquiry {\n            padding: 6rem 0;\n            background: #F5F5F5;\n        }\n\n        .Logisticsinquiry_h2 {\n            margin: 0 0 3rem;\n            text-align: center;\n        }\n\n        .Logisticsinquiry_box_input {\n            display: flex;\n            width: 100%;\n        }\n\n        .Logisticsinquiry_box_input_text {\n            border: 0;\n            padding: 1rem;\n            width: 35rem;\n            height: 5rem;\n            line-height: 5rem;\n            font-size: 1.4rem;\n            width: 80%;\n        }\n\n        .Logisticsinquiry_box_input_btn {\n            background-color: #FF4F00;\n            color: #FFFFFF;\n            border-radius: 0.5rem;\n            border: 0;\n            padding: 0 0rem;\n            font-size: 1.4rem;\n            font-weight: 700;\n            height: 5rem;\n            line-height: 5rem;\n            cursor: pointer;\n            transition: background-color 0.3s, color 0.3s;\n            width: 20%;\n        }\n    }\n</style>\n<div class=\"Logisticsinquiry\">\n    <h2 class=\"h2 Logisticsinquiry_h2\">Order Tracking</h2>\n    <div class=\"Logisticsinquiry_box container\">\n        <div class=\"Logisticsinquiry_box_input\">\n            <input class=\"Logisticsinquiry_box_input_text\" type=\"text\" id=\"YQNum\" maxlength=\"50\"\n                placeholder=\"Please enter your tracking number\" />\n            <input class=\"Logisticsinquiry_box_input_btn\" type=\"button\" value=\"TRACK\" onclick=\"doTrack()\" />\n        </div>\n    </div>\n    <div id=\"YQContainer\"></div>\n</div>\n\n\n<script type=\"text/javascript\" src=\"//www.17track.net/externalcall.js\"></script>\n<script type=\"text/javascript\">\n    function doTrack() {\n        var num = document.getElementById(\"YQNum\").value;\n        if (num === \"\") {\n            alert(\"Enter your number.\");\n            return;\n        }\n        YQV5.trackSingle({\n            YQ_ContainerId: \"YQContainer\",\n            YQ_Height: 560,\n            YQ_Fc: \"0\",\n            YQ_Lang: \"en\",\n            YQ_Num: num\n        });\n    }\n</script>"
      }
    },
