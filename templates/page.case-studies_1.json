        "column_V4RMyJ": {
          "type": "column",
          "settings": {
            "icon": "none",
            "icon_color_scheme": "background-1",
            "icon_fill_type": "gradient",
            "heading": "",
            "text": "The World Health Organization (WHO) recognizes hearing loss as a growing global health concern, not only because it is so common, but because it so often goes unnoticed.",
            "show_button": false,
            "button_label": "Label",
            "button_link": "",
            "button_style": "simple"
          }
        },
        "column_Hi8wXG": {
          "type": "column",
          "settings": {
            "icon": "none",
            "icon_color_scheme": "background-1",
            "icon_fill_type": "gradient",
            "heading": "",
            "text": "Over time, even mild, untreated changes can begin to shape how we communicate, connect, and participate in daily life.",
            "show_button": false,
            "button_label": "Label",
            "button_link": "",
            "button_style": "simple"
          }
        },
        "column_jxbrrC": {
          "type": "column",
          "settings": {
            "icon": "none",
            "icon_color_scheme": "background-1",
            "icon_fill_type": "gradient",
            "heading": "",
            "text": "That’s why World Hearing Day exists: not to create fear — but to encourage earlier awareness, before small changes become lasting challenges.",
            "show_button": false,
            "button_label": "Label",
            "button_link": "",
            "button_style": "simple"
          }
        }
      },
