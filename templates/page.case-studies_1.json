            "icon_color_scheme": "background-1",
            "icon_fill_type": "gradient",
            "heading": "",
            "text": "Hearing loss affects far more adults than many expect — and it often begins quietly, long before retirement age.",
            "show_button": false,
            "button_label": "Label",
