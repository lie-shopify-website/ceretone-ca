    "custom_collapsible_image_qYPzpL": {
      "type": "custom-collapsible-image",
      "blocks": {
        "accordion_YmBhpj": {
          "type": "accordion",
          "settings": {
            "question": "Hearing loss doesn’t only affect the ears — it affects the brain.",
            "answer": "<p>New research from Johns Hopkins shows a clear connection between hearing and brain health.</p><p>\nWearing hearing aids has been linked to a reduced risk of dementia — by <strong>up to 61%</strong>.</p><p>\nAddressing hearing loss earlier may help lessen the strain hearing loss places on the brain.</p><p></p>",
            "opened": false
          }
        },
        "accordion_AkgLj6": {
          "type": "accordion",
          "settings": {
            "question": "Hearing loss doesn’t arrive all at once — it builds over time.",
            "answer": "<p>Hearing loss becomes more common with age — often without being noticed.\nIts prevalence is frequently described as <strong>doubling with each decade</strong> of life.</p><p>\nBecause these changes happen gradually, many people adapt without realizing their hearing has changed.</p>",
            "opened": false
          }
        },
        "accordion_cMxpac": {
          "type": "accordion",
          "settings": {
            "question": "Hearing loss doesn’t stop at sound — it affects how we feel.",
            "answer": "<p>Conversations become tiring. Social moments feel distant. Many people begin to withdraw — without realizing why.</p><p>\nIn adults with moderate or worse hearing loss, rates of depression are <strong>more than twice as high.</strong></p>",
            "opened": false
          }
        }
      },
      "block_order": [
        "accordion_YmBhpj",
