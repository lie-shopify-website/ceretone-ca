        "color": "#ffffff",
        "btn_label": "<strong>Get better hearing now</strong>",
        "btn_link": "https://ceretone.com/pages/forbes-offer#a90-purchase",
        "btn_max_width": 240,
        "btn_max_width_mb": 240,
        "liquid": "<style>\n.sticky-btn {display:none;}\n</style>\n<script>\n  // 页面加载完成后执行（确保 DOM 元素已渲染）\n  document.addEventListener('DOMContentLoaded', function() {\n    // 获取目标元素\n    const featuredProduct = document.querySelector('.featured-product');\n    const stickyBtn = document.querySelector('.sticky-btn');\n\n    // 若页面没有 .featured-product 模块，直接终止逻辑\n    if (!featuredProduct || !stickyBtn) return;\n\n    // 核心函数：判断是否滚动到模块底部，并控制按钮\n    function checkScrollToModuleBottom() {\n      // 计算模块底部到页面顶部的距离（模块顶部距离 + 模块高度）\n      const moduleBottom = featuredProduct.getBoundingClientRect().top + window.pageYOffset + featuredProduct.offsetHeight;\n      // 计算当前页面滚动的总距离（文档滚动距离 + 窗口可视高度）\n      const scrollBottom = window.scrollY + window.innerHeight;\n\t \n\n      // 当滚动到模块底部（允许 100px 误差，提升用户体验）\n      if (scrollBottom >= moduleBottom + 20) {\n        stickyBtn.style.display = 'block';\n      } else {\n        stickyBtn.style.display = 'none';\n      }\n    }\n    // 监听滚动事件：实时判断是否滚动到模块底部\n    window.addEventListener('scroll', checkScrollToModuleBottom);\n\n    // 监听窗口大小变化：适配不同屏幕尺寸（如手机旋转后）\n    window.addEventListener('resize', checkScrollToModuleBottom);\n\n    // 页面加载完成后，首次执行一次（处理初始滚动位置）\n    checkScrollToModuleBottom();\n  });\n</script>"
      }
    },
