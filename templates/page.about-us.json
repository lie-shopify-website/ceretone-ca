    "custom_liquid_gfpCqK": {
      "type": "custom-liquid",
      "name": "Our Story",
      "settings": {
        "custom_liquid_text": "",
        "custom_liquid": "<div class=\"abs-our-story\">\n    <div class=\"our-story-inner\">\n        <div class=\"safe-container\">\n            <div class=\"top\">\n                <div class=\"heading\">\n                    <div class=\"heading-title\"><h2>Our Story</h2></div>\n                </div>\n            </div>\n\n            <div class=\"bottom\">\n                <div class=\"image\">\n                    <picture>\n                        <source srcset=\"https://cdn.shopify.com/s/files/1/0517/0436/5244/files/8_177a9241-e6ab-46b5-87e7-469d399eab15.png?v=1765953640\"  media=\"(max-width: 1199px)\" />\n                        <source srcset=\"https://cdn.shopify.com/s/files/1/0517/0436/5244/files/8_177a9241-e6ab-46b5-87e7-469d399eab15.png?v=1765953640\" media=\"(min-width: 1200px)\" />\n                        <img src=\"https://cdn.shopify.com/s/files/1/0517/0436/5244/files/8_177a9241-e6ab-46b5-87e7-469d399eab15.png?v=1765953640\" width=\"100%\" height=\"auto\" />\n                    </picture>\n                </div>\n\n                <div class=\"content\">\n                    <div class=\"p\"><p>“In 2009, an engineer watched his father lose his hearing. Affordable, effective hearing aids simply didn't exist—he couldn't find a solution in time. From that loss came a mission: no one else should face this choice.</p></div>\n                    <div class=\"p\"><p>Founded on that promise, Ceretone set out to deliver top performance at a price everyone can afford. Established in 2020 in the United States, Ceretone is a brand under Audicon Corporation. What began as one family's mission has grown into a global commitment, helping people reconnect with the world around them.</p></div>\n                    <div class=\"p\"><p>Today, our patent‑protected technology serves families everywhere. Because sound is meant for all, we're committed to being accessible to anyone, anywhere.”</p></div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>"
      }
