{% assign selected_variant_id = product.selected_or_first_available_variant.id %}
<div class="main-media-gallery">

    <div class="big-image-swiper-list">
        {% for variant in product.variants %}
            {% if variant.metafields.custom.variant_media_list.value == blank %} {% continue %} {% endif %} {% comment %} 没有图片就不显示 {% endcomment %}

            <div class="swiper-box" data-index="variant-id-{{ variant.id }}" data-position="{{ forloop.index }}" {% unless selected_variant_id == variant.id %}style="display:none;"{% endunless %}>
                <div class="swiper big-image-swiper">
                    <div class="swiper-wrapper">
                        {% if variant.metafields.custom.variant_media_list.value != blank %}
                            {%  assign medias = variant.metafields.custom.variant_media_list.value %}
                            {%- for media in medias -%}
                                {% render 'media-item', media:media, class:'swiper-slide', position:forloop.index %}
                            {% endfor %}
                        {% endif %}
                    </div>
                </div>
                <div class="product__slider-nav no-js-hidden">
                    <div class="swiper-button-prev focus-inset">
                        <svg width="29" height="29" viewBox="0 0 29 29" fill="none" style="transform: rotate(180deg);" xmlns="http://www.w3.org/2000/svg">
                            <g opacity="0.5">
                            <rect width="18.5667" height="15.5256" transform="matrix(-4.37114e-08 -1 -1 4.37114e-08 21.6875 22.8082)" fill="#FFFEFB"></rect>
                            <path d="M14.0396 13.9707L13.9708 14.0394C13.9927 14.0144 14.0145 13.9925 14.0396 13.9707Z" fill="white"></path>
                            <path d="M14.005 28.01C6.271 28.01 0 21.739 0 14.005C0 6.27099 6.271 -1.33514e-05 14.005 -1.33514e-05C21.739 -1.33514e-05 28.01 6.27099 28.01 14.005C28.01 21.739 21.739 28.01 14.005 28.01ZM17.6876 13.3298L17.6188 13.261L16.9467 12.5889L11.7667 7.4089C11.3791 7.02126 10.7414 7.02126 10.3506 7.4089C9.96295 7.79654 9.96295 8.43427 10.3506 8.82503L15.5337 14.005L10.3537 19.1881C9.96607 19.5758 9.96607 20.2135 10.3537 20.6043C10.7414 20.9919 11.3791 20.9919 11.7667 20.6011L16.9467 15.4211L17.6282 14.7397L17.6845 14.6834C17.8502 14.5052 17.9502 14.2645 17.9471 14.0019C17.9471 13.7424 17.8502 13.508 17.6876 13.3298Z" fill="#2D2D2D"></path>
                            </g>
                        </svg>
                    </div>
                    <div class="swiper-button-next focus-inset">
                        <svg width="29" height="29" viewBox="0 0 29 29" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <g opacity="0.5">
                            <rect width="18.5667" height="15.5256" transform="matrix(-4.37114e-08 -1 -1 4.37114e-08 21.6875 22.8082)" fill="#FFFEFB"></rect>
                            <path d="M14.0396 13.9707L13.9708 14.0394C13.9927 14.0144 14.0145 13.9925 14.0396 13.9707Z" fill="white"></path>
                            <path d="M14.005 28.01C6.271 28.01 0 21.739 0 14.005C0 6.27099 6.271 -1.33514e-05 14.005 -1.33514e-05C21.739 -1.33514e-05 28.01 6.27099 28.01 14.005C28.01 21.739 21.739 28.01 14.005 28.01ZM17.6876 13.3298L17.6188 13.261L16.9467 12.5889L11.7667 7.4089C11.3791 7.02126 10.7414 7.02126 10.3506 7.4089C9.96295 7.79654 9.96295 8.43427 10.3506 8.82503L15.5337 14.005L10.3537 19.1881C9.96607 19.5758 9.96607 20.2135 10.3537 20.6043C10.7414 20.9919 11.3791 20.9919 11.7667 20.6011L16.9467 15.4211L17.6282 14.7397L17.6845 14.6834C17.8502 14.5052 17.9502 14.2645 17.9471 14.0019C17.9471 13.7424 17.8502 13.508 17.6876 13.3298Z" fill="#2D2D2D"></path>
                            </g>
                        </svg>
                    </div>
                </div>
            </div>

        {% endfor %}
    </div>

    <div class="thumbs-image-swiper-list">
        {% for variant in product.variants %}
            {% if variant.metafields.custom.variant_media_list.value == blank %} {% continue %} {% endif %} {% comment %} 没有图片就不显示 {% endcomment %}

            <div class="swiper-box" data-index="variant-id-{{ variant.id }}" data-position="{{ forloop.index }}" {% unless selected_variant_id == variant.id %}style="display:none;"{% endunless %}>
                <div class="thumbs-slider-container">
                    <div class="swiper thumbs-slider">
                            <div class="swiper-wrapper">
                                {% if variant.metafields.custom.variant_media_list.value != blank %}
                                    {%  assign medias = variant.metafields.custom.variant_media_list.value %}
                                    {%- for media in medias -%}
                                        <div class="swiper-slide">
                                            <div class="image">
                                                <img src="{{ media.src |  image_url: width: 100 }}" width="auto" height="auto" />
                                            </div>
                                        </div>
                                    {% endfor %}
                                {% endif %}
                                
                            </div>
                    </div>
                </div>

                <script>
                    ;(function() {

                        window.addEventListener('DOMContentLoaded', function() {
                            /* media swiper */
                            mainThumbsSlider{{ forloop.index }} = new Swiper('.main-media-gallery [data-index="variant-id-{{ variant.id }}"] .thumbs-slider', {
                                spaceBetween: 7,
                                slidesPerView: 6,

                                // 自定义点击逻辑
                                on: {
                                    click: function(swiper, event) {
                                    const clickedIndex = swiper.clickedIndex;
                                    const activeIndex = swiper.activeIndex;
                                    const slidesPerView = swiper.params.slidesPerView;
                                    const slidesLength = swiper.slides.length;
                                    
                                    // 计算边界
                                    const visibleStart = activeIndex;
                                    const visibleEnd = activeIndex + slidesPerView - 1;
                                    
                                    // 点击右侧边缘的缩略图
                                    if (clickedIndex === visibleEnd && clickedIndex < slidesLength - 1) {
                                        // 点击第4个（索引3），显示第5个
                                        swiper.slideTo(clickedIndex - 2); // 向前移动2个位置
                                    }
                                    // 点击左侧边缘的缩略图
                                    else if (clickedIndex === visibleStart && clickedIndex > 0) {
                                        // 点击当前显示的第一个，显示前一个
                                        swiper.slideTo(clickedIndex - 1);
                                    }
                                    // 正常情况让 slideToClickedSlide 处理 
                                    }
                                },
                                
                                breakpoints: {
                                    1200: {
                                        direction: "vertical",
                                        spaceBetween: 12,
                                    },
                                },
                            });
    
                            {% comment %} 大图swiper需要被window.xxx赋值，否则在media-gallery.liquid中无法获取到swiper实例 {% endcomment %}
                            window.mainBigPcImageSwiper{{ forloop.index }} = new Swiper('.main-media-gallery [data-index="variant-id-{{ variant.id }}"] .big-image-swiper', {
                                spaceBetween: 10,
                                slidesPerView: 1,
                                navigation: {
                                    nextEl: '.main-media-gallery [data-index="variant-id-{{ variant.id }}"] .swiper-button-next',
                                    prevEl: '.main-media-gallery [data-index="variant-id-{{ variant.id }}"] .swiper-button-prev',
                                },
                                
                                thumbs: {
                                    swiper: mainThumbsSlider{{ forloop.index }},
                                },
                                on: {
                                    slideChangeTransitionStart: function () {
                                        if(mainBigPcImageSwiper{{ forloop.index }} && mainThumbsSlider{{ forloop.index }}){
                                            mainThumbsSlider{{ forloop.index }}.slideTo(
                                                mainBigPcImageSwiper{{ forloop.index }}.activeIndex,
                                            )
                                        }
                                    },
                                }
                            });
    
                        });
                    })();
                </script> 

            </div>

            

        {% endfor %}
    </div>

</div>
